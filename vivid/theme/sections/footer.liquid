{%- comment -%}
  Footer — trust band (3 big stats) + brand/menu/social grid + certs row
  + payment methods + bottom legal row. Mirrors vivid/index.html <footer>.
{%- endcomment -%}

<footer>
  <div class="container">

    {%- comment -%} Footer trust band (top stats) — schema-driven {%- endcomment -%}
    {%- if section.settings.show_trust -%}
      <div class="foot-trust">
        <div class="foot-trust-cell">
          <div class="foot-trust-num">{{ section.settings.trust_1_num }}</div>
          <div class="foot-trust-lbl">{{ section.settings.trust_1_lbl }}</div>
        </div>
        <div class="foot-trust-cell">
          <div class="foot-trust-num">{{ section.settings.trust_2_num }}</div>
          <div class="foot-trust-lbl">{{ section.settings.trust_2_lbl }}</div>
        </div>
        <div class="foot-trust-cell">
          <div class="foot-trust-num">{{ section.settings.trust_3_num }}</div>
          <div class="foot-trust-lbl">{{ section.settings.trust_3_lbl }}</div>
        </div>
      </div>
    {%- endif -%}

    <div class="foot-grid">
      <div class="foot-col">
        <img
          src="{{ 'vivid-logo-wordmark.svg' | asset_url }}"
          class="foot-brand-logo foot-brand-logo--svg"
          width="640"
          height="200"
          alt="{{ shop.name }}"
          loading="lazy"
        >
        <p class="foot-lede">{{ section.settings.brand_lede }}</p>
        {%- if section.blocks.size > 0 -%}
          {%- assign has_social = false -%}
          {%- for b in section.blocks -%}{%- if b.type == 'social' -%}{%- assign has_social = true -%}{%- endif -%}{%- endfor -%}
          {%- if has_social -%}
            <div class="social-icons" style="margin-top:18px">
              {%- for b in section.blocks -%}
                {%- if b.type == 'social' -%}
                  <a href="{{ b.settings.url }}" target="_blank" rel="noopener" aria-label="{{ b.settings.platform }}">
                    {%- case b.settings.platform -%}
                      {%- when 'Instagram' -%}<svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
                      {%- when 'TikTok' -%}<svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1v-3.5a6.37 6.37 0 00-.79-.05A6.34 6.34 0 003.15 15.2a6.34 6.34 0 0010.86 4.48v-7.1a8.16 8.16 0 005.58 2.19v-3.45a4.85 4.85 0 01-1.99-2.63 4.83 4.83 0 001.99-2z"/></svg>
                      {%- when 'Facebook' -%}<svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
                      {%- when 'WhatsApp' -%}<svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
                    {%- endcase -%}
                  </a>
                {%- endif -%}
              {%- endfor -%}
            </div>
          {%- endif -%}
        {%- endif -%}
      </div>

      {%- for block in section.blocks -%}
        {%- if block.type == 'menu' -%}
          <div class="foot-col" {{ block.shopify_attributes }}>
            <h5>{{ block.settings.heading }}</h5>
            <ul>
              {%- for link in block.settings.menu.links -%}
                <li><a href="{{ link.url }}">{{ link.title }}</a></li>
              {%- endfor -%}
            </ul>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>

    {%- if section.settings.show_certs -%}
      <div class="foot-certs" role="list" aria-label="Certifications">
        {%- assign certs = section.settings.certs | split: ',' -%}
        {%- for cert in certs -%}
          <span class="cert" role="listitem">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 12l2 2 4-4M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            {{ cert | strip }}
          </span>
        {%- endfor -%}
      </div>
    {%- endif -%}

    {%- if section.settings.show_pay -%}
      <div class="foot-pay" aria-label="Accepted payment methods">
        {%- assign methods = section.settings.payment_methods | split: ',' -%}
        {%- for m in methods -%}
          <span>{{ m | strip }}</span>
        {%- endfor -%}
      </div>
    {%- endif -%}

    <div class="foot-bottom">
      <div>© {{ 'now' | date: '%Y' }} {{ shop.name }} · Operated by Interlife Wholesalers (Pty) Ltd · All prices in ZAR · incl. 15% VAT</div>
      <div>
        <a href="/pages/shipping-and-returns">Shipping & returns</a> ·
        <a href="/policies/privacy-policy">Privacy</a> ·
        <a href="/policies/terms-of-service">Terms</a> ·
        <a href="/pages/popia">POPIA</a>
      </div>
    </div>

  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "tag": "footer",
  "settings": [
    { "type": "image_picker", "id": "logo_light", "label": "Logo (light, for dark footer)" },
    { "type": "textarea",     "id": "brand_lede", "label": "Brand lede",
      "default": "Plant-based supplements made in South Africa. Ancient remedies, modern science, vegetable capsules." },
    { "type": "header",   "content": "Trust band" },
    { "type": "checkbox", "id": "show_trust", "label": "Show trust band", "default": true },
    { "type": "text", "id": "trust_1_num", "label": "Trust 1 · number", "default": "12,000+" },
    { "type": "text", "id": "trust_1_lbl", "label": "Trust 1 · label",  "default": "South Africans served" },
    { "type": "text", "id": "trust_2_num", "label": "Trust 2 · number", "default": "0" },
    { "type": "text", "id": "trust_2_lbl", "label": "Trust 2 · label",  "default": "proprietary blends" },
    { "type": "text", "id": "trust_3_num", "label": "Trust 3 · number", "default": "Since 1996." },
    { "type": "text", "id": "trust_3_lbl", "label": "Trust 3 · label",  "default": "Family-founded, Centurion-made" },
    { "type": "header",   "content": "Certifications" },
    { "type": "checkbox", "id": "show_certs", "label": "Show certifications strip", "default": true },
    { "type": "text",     "id": "certs",     "label": "Certifications (comma-separated)",
      "default": "SAHPRA-aligned facility, Third-party lab tested, Vegetarian capsules, Made in South Africa" },
    { "type": "header",   "content": "Payment methods" },
    { "type": "checkbox", "id": "show_pay",  "label": "Show payment methods strip", "default": true },
    { "type": "text",     "id": "payment_methods", "label": "Payment methods (comma-separated)",
      "default": "Visa, Mastercard, Payfast, SnapScan, EFT" }
  ],
  "blocks": [
    {
      "type": "menu",
      "name": "Menu column",
      "settings": [
        { "type": "text",      "id": "heading", "label": "Heading", "default": "Shop" },
        { "type": "link_list", "id": "menu",    "label": "Menu" }
      ]
    },
    {
      "type": "social",
      "name": "Social link",
      "settings": [
        { "type": "select", "id": "platform", "label": "Platform",
          "options": [
            { "value": "Instagram", "label": "Instagram" },
            { "value": "TikTok",    "label": "TikTok"    },
            { "value": "Facebook",  "label": "Facebook"  },
            { "value": "WhatsApp",  "label": "WhatsApp"  }
          ],
          "default": "Instagram" },
        { "type": "url", "id": "url", "label": "URL" }
      ]
    }
  ],
  "presets": [{ "name": "Footer" }]
}
{% endschema %}
