<section class="page-shell">
  <div class="container">
    <div class="page-head">
      <div class="eyebrow">{{ section.settings.eyebrow }}</div>
      <h1>{{ page.title }}</h1>
    </div>
    <div class="rte page-rte">
      {{ page.content }}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Main page",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Vivid Health" }
  ]
}
{% endschema %}
