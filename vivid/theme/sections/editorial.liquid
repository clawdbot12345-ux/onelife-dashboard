<section style="background:var(--bone);border-top:1px solid var(--line);border-bottom:1px solid var(--line)">
  <div class="container split">
    {%- if section.settings.image != blank -%}
      <div class="editorial-img">
        <div class="lab">{{ section.settings.image_label }}</div>
        <img src="{{ section.settings.image | image_url: width: 1000 }}" alt="" loading="lazy">
      </div>
    {%- endif -%}
    <div class="editorial-body">
      <div class="kicker">{{ section.settings.kicker }}</div>
      <h2>{{ section.settings.heading }}</h2>
      {{ section.settings.body }}
      {%- if section.settings.cta_link != blank -%}
        <div style="margin-top:24px"><a href="{{ section.settings.cta_link }}" class="btn btn--forest btn-arrow">{{ section.settings.cta_label }}</a></div>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Editorial block",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Image" },
    { "type": "text", "id": "image_label", "label": "Image tag", "default": "The Vivid Lab" },
    { "type": "text", "id": "kicker", "label": "Kicker", "default": "Our philosophy" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "We don't believe in fairy dusting." },
    { "type": "richtext", "id": "body", "label": "Body" },
    { "type": "text", "id": "cta_label", "label": "CTA label", "default": "Read the full story" },
    { "type": "url", "id": "cta_link", "label": "CTA link" }
  ],
  "presets": [{ "name": "Editorial block" }]
}
{% endschema %}
