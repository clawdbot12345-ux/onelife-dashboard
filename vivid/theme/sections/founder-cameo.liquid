{%- comment -%}
  Founder cameo — portrait + quote + attribution. Gives the brand a face
  between the editorial dark sections. If no portrait image is set,
  falls back to a monogram-on-forest treatment.
  Source of truth: vivid/index.html .founder-band block.
{%- endcomment -%}

<section class="founder-band reveal" aria-label="Founder">
  <div class="container">
    <div class="founder-grid">
      <div class="founder-portrait" aria-hidden="true">
        {%- if section.settings.portrait != blank -%}
          {{ section.settings.portrait | image_url: width: 480 | image_tag:
              loading: 'lazy',
              widths: '180,360,480',
              sizes: '180px',
              alt: section.settings.attribution | strip_html }}
        {%- else -%}
          <div class="founder-monogram">{{ section.settings.monogram | default: 'DR' }}</div>
        {%- endif -%}
        {%- if section.settings.since != blank -%}
          <span class="founder-since">{{ section.settings.since }}</span>
        {%- endif -%}
      </div>
      <div>
        {%- if section.settings.eyebrow != blank -%}
          <div class="founder-eyebrow">{{ section.settings.eyebrow }}</div>
        {%- endif -%}
        <blockquote class="founder-quote">{{ section.settings.quote }}</blockquote>
        {%- if section.settings.attribution != blank -%}
          <div class="founder-attr">{{ section.settings.attribution }}</div>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Founder cameo",
  "tag": "section",
  "class": "section-founder-cameo",
  "settings": [
    { "type": "image_picker", "id": "portrait",    "label": "Portrait (180x220, vertical)" },
    { "type": "text",         "id": "monogram",    "label": "Fallback monogram (if no portrait)", "default": "DR" },
    { "type": "text",         "id": "since",       "label": "Since-tag on portrait", "default": "Est. 1996" },
    { "type": "text",         "id": "eyebrow",     "label": "Eyebrow", "default": "Founder · Centurion, since 1996" },
    { "type": "richtext",     "id": "quote",       "label": "Quote",
      "default": "<p>\"My family started Onelife Health in 1996 because we couldn't find supplements that <em>showed their work.</em> Vivid is the formulation arm — every milligram, on every label, every time.\"</p>" },
    { "type": "richtext",     "id": "attribution", "label": "Attribution",
      "default": "<p><strong>Devakar Ramdass</strong> · Founder, Onelife Health &amp; Vivid Health</p>" }
  ],
  "presets": [
    { "name": "Founder cameo" }
  ]
}
{% endschema %}
