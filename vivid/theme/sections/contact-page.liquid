<section class="page-shell">
  <div class="container">
    <div class="page-head">
      <div class="eyebrow">{{ section.settings.eyebrow }}</div>
      <h1>{{ section.settings.heading }}</h1>
      <p>{{ section.settings.lede }}</p>
    </div>

    <div class="contact-grid">
      <div>
        <a class="contact-method" href="mailto:orders@vividhealthsa.co.za">
          <span class="contact-method-ico" aria-hidden="true">
            <svg width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><path d="M4 6h16v12H4z"/><path d="m4 7 8 6 8-6"/></svg>
          </span>
          <span>
            <h4>Order support</h4>
            <p>orders@vividhealthsa.co.za</p>
            <span class="meta">Orders, returns, deliveries</span>
          </span>
        </a>
        <a class="contact-method" href="mailto:info@vividhealthsa.co.za">
          <span class="contact-method-ico" aria-hidden="true">
            <svg width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><circle cx="12" cy="12" r="9"/><path d="M12 8h.01M11 12h1v5h1"/></svg>
          </span>
          <span>
            <h4>Product questions</h4>
            <p>info@vividhealthsa.co.za</p>
            <span class="meta">Ingredients, suitability, store help</span>
          </span>
        </a>
        <a class="contact-method" href="tel:+27126543740">
          <span class="contact-method-ico" aria-hidden="true">
            <svg width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><path d="M22 16.9v3a2 2 0 0 1-2.2 2 19.8 19.8 0 0 1-8.6-3.1 19.5 19.5 0 0 1-6-6A19.8 19.8 0 0 1 2.1 4.2 2 2 0 0 1 4.1 2h3a2 2 0 0 1 2 1.7c.1 1 .4 2 .7 2.9a2 2 0 0 1-.5 2.1L8.1 9.9a16 16 0 0 0 6 6l1.2-1.2a2 2 0 0 1 2.1-.5c.9.3 1.9.6 2.9.7a2 2 0 0 1 1.7 2z"/></svg>
          </span>
          <span>
            <h4>Phone</h4>
            <p>012 654 3740</p>
            <span class="meta">South Africa</span>
          </span>
        </a>
      </div>

      <div class="contact-panel">
        {% form 'contact', class: 'form-grid' %}
          {%- if form.posted_successfully? -%}
            <p class="form-success">Message sent. We will reply as soon as possible.</p>
          {%- endif -%}
          {%- if form.errors -%}
            <div class="form-error">{{ form.errors | default_errors }}</div>
          {%- endif -%}
          <label>
            Name
            <input type="text" name="contact[name]" autocomplete="name" required>
          </label>
          <label>
            Email
            <input type="email" name="contact[email]" autocomplete="email" required>
          </label>
          <label>
            Topic
            <select name="contact[topic]">
              <option>Order support</option>
              <option>Product question</option>
              <option>Wholesale or retail</option>
              <option>POPIA request</option>
            </select>
          </label>
          <label>
            Message
            <textarea name="contact[body]" required></textarea>
          </label>
          <button class="btn btn--forest" type="submit">Send message</button>
        {% endform %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Contact page",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Contact" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Speak to Vivid Health." },
    { "type": "textarea", "id": "lede", "label": "Lede", "default": "Order support, formulation questions, returns, and privacy requests all start here." }
  ]
}
{% endschema %}
