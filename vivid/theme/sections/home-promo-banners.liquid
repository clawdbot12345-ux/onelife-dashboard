<section class="home-promo-banners reveal" aria-label="Vivid Health shopping routes">
  <div class="container">
    <div class="promo-banner-grid">
      <a class="promo-banner promo-banner--quiz" href="/pages/quiz">
        <span class="promo-banner-bg" style="background-image:url('{{ 'banner-hero-kitchen.jpg' | asset_url }}')"></span>
        <span class="promo-banner-copy">
          <em>Premium quiz</em>
          <strong>Find the formula that fits your day.</strong>
          <small>Three questions. A cleaner starting point.</small>
        </span>
      </a>
      <a class="promo-banner promo-banner--stack" href="{{ routes.collections_url }}/bundles">
        <span class="promo-banner-bg" style="background-image:url('{{ 'hero-group.jpg' | asset_url }}')"></span>
        <span class="promo-banner-copy">
          <em>Curated stacks</em>
          <strong>Build the routine. Save 10%.</strong>
          <small>Allergy, mobility, and evening support.</small>
        </span>
      </a>
      <a class="promo-banner promo-banner--consult" href="https://wa.me/27713744910?text=Hi%2C%20I%27d%20like%20a%20free%20Vivid%20Health%20consultation" target="_blank" rel="noopener">
        <span class="promo-banner-bg" style="background-image:url('{{ 'bone-supreme-influencer.jpg' | asset_url }}')"></span>
        <span class="promo-banner-copy">
          <em>Free consultation</em>
          <strong>Ask before you combine.</strong>
          <small>Human guidance for dose, timing, and fit.</small>
        </span>
      </a>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Home promo banners",
  "presets": [{ "name": "Home promo banners" }]
}
{% endschema %}
