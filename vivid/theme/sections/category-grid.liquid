{%- comment -%}
  Goal grid — 8 colored outcome tiles with hybrid naming. Each tile
  shows the marketing name as the headline AND the bottle-printed
  label as a small tag, so customers can match the website nav to
  what's printed on the physical bottle.
  Source of truth: vivid/index.html .goals block.
{%- endcomment -%}

<section class="reveal" aria-labelledby="goals-heading">
  <div class="container">
    <div class="section-head">
      <div>
        {%- if section.settings.eyebrow != blank -%}
          <div class="eyebrow">{{ section.settings.eyebrow }}</div>
        {%- endif -%}
        <h2 id="goals-heading" style="margin-top:14px">{{ section.settings.heading }}</h2>
      </div>
      {%- if section.settings.lead != blank -%}
        <p class="lead">{{ section.settings.lead }}</p>
      {%- endif -%}
    </div>
    <div class="goals">
      {%- for block in section.blocks -%}
        {%- assign coll = collections[block.settings.collection] -%}
        {%- assign tile_url = coll.url | default: block.settings.fallback_url -%}
        {%- assign count = coll.products_count -%}
        {%- assign show_label = false -%}
        {%- if block.settings.label != blank and block.settings.label != block.settings.name -%}
          {%- assign show_label = true -%}
        {%- endif -%}
        <a href="{{ tile_url }}" class="goal goal--{{ block.settings.goal_id }}" aria-label="{{ block.settings.name }}" {{ block.shopify_attributes }}>
          <div class="goal-bg"></div>
          <div class="goal-shape"></div>
          {%- if block.settings.icon_path != blank -%}
            <div class="goal-botanical" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"><path d="{{ block.settings.icon_path }}"/></svg>
            </div>
          {%- endif -%}
          <div class="goal-content">
            <div class="goal-tag">
              {%- if show_label -%}{{ block.settings.label }} · {% endif -%}
              {%- if count > 0 -%}{{ count }} formulations{%- else -%}{{ block.settings.fallback_count | default: 'Shop now' }}{%- endif -%}
            </div>
            <div><div class="goal-name">{{ block.settings.name | replace: '&', '<em>&</em>' }}</div></div>
            <div class="goal-meta">
              <span>{{ block.settings.tagline }}</span>
              <span class="arrow"><svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><path d="M5 12h14M13 6l6 6-6 6"/></svg></span>
            </div>
          </div>
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Goal grid",
  "tag": "section",
  "class": "section-goal-grid",
  "settings": [
    { "type": "text",     "id": "eyebrow", "label": "Eyebrow", "default": "Shop by goal" },
    { "type": "richtext", "id": "heading", "label": "Heading", "default": "<p>Pick the system <em>you're working on.</em></p>" },
    { "type": "textarea", "id": "lead",    "label": "Lead",    "default": "Eight focused ranges. Tap one to see the formulations made for it." }
  ],
  "max_blocks": 8,
  "blocks": [
    {
      "type": "goal",
      "name": "Goal tile",
      "settings": [
        { "type": "text",       "id": "name",        "label": "Display name (marketing)", "default": "Stress, Sleep & Mood" },
        { "type": "text",       "id": "label",       "label": "Bottle-printed label",     "default": "Mental Health",
          "info": "What's printed on the bottle. Shown as a small tag above the headline. Leave matching the display name to hide." },
        { "type": "text",       "id": "tagline",     "label": "Tagline",     "default": "Calm without sedation" },
        { "type": "select",     "id": "goal_id",     "label": "Goal palette",
          "options": [
            { "value": "gut",      "label": "Gut" },
            { "value": "immunity", "label": "Immunity" },
            { "value": "energy",   "label": "Energy" },
            { "value": "stress",   "label": "Stress / Mental" },
            { "value": "joints",   "label": "Joints / Physical" },
            { "value": "women",    "label": "Women's" },
            { "value": "men",      "label": "Men's" },
            { "value": "daily",    "label": "Daily Nutrients" }
          ],
          "default": "stress" },
        { "type": "collection", "id": "collection",  "label": "Linked collection" },
        { "type": "url",        "id": "fallback_url","label": "Fallback URL (if no collection set)" },
        { "type": "text",       "id": "fallback_count","label": "Fallback subtitle (if no products)" },
        { "type": "textarea",   "id": "icon_path",   "label": "Botanical SVG path (decorative accent)",
          "default": "M21 12.8A9 9 0 1 1 11.2 3 7 7 0 0 0 21 12.8z" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Goal grid",
      "blocks": [
        { "type": "goal", "settings": { "goal_id": "gut",      "name": "Gut Health",            "label": "Gut Health",       "tagline": "Cleanse, balance, restore",     "icon_path": "M3 12c2-4 6-6 9-6s7 2 9 6c-2 4-6 6-9 6s-7-2-9-6z" } },
        { "type": "goal", "settings": { "goal_id": "immunity", "name": "Immunity",              "label": "Immune Health",    "tagline": "Daily defense, year-round",     "icon_path": "M12 2l3 6 6 1-4.5 4.5L18 20l-6-3-6 3 1.5-6.5L3 9l6-1z" } },
        { "type": "goal", "settings": { "goal_id": "energy",   "name": "Energy & Vitality",     "label": "Nutrient Health",  "tagline": "Cellular fuel, not stimulants", "icon_path": "M13 2L3 14h7l-1 8 10-12h-7z" } },
        { "type": "goal", "settings": { "goal_id": "stress",   "name": "Stress, Sleep & Mood",  "label": "Mental Health",    "tagline": "Calm without sedation",         "icon_path": "M21 12.8A9 9 0 1 1 11.2 3 7 7 0 0 0 21 12.8z" } },
        { "type": "goal", "settings": { "goal_id": "joints",   "name": "Joints & Mobility",     "label": "Physical Health",  "tagline": "Move freely, age strongly",     "icon_path": "M6 6l4 4-2 2-4-4 2-2zm12 12l-4-4 2-2 4 4-2 2zM10 14l4-4" } },
        { "type": "goal", "settings": { "goal_id": "women",    "name": "Women's Health",        "label": "Women's Health",   "tagline": "Hormones, cycles, balance",     "icon_path": "M12 14a5 5 0 1 0 0-10 5 5 0 0 0 0 10zm0 0v8m-3-4h6" } },
        { "type": "goal", "settings": { "goal_id": "men",      "name": "Men's Health",          "label": "Men's Health",     "tagline": "Prostate, vitality, focus",     "icon_path": "M14 4h6v6M20 4L13 11m-7 9a5 5 0 1 1 0-10 5 5 0 0 1 0 10z" } },
        { "type": "goal", "settings": { "goal_id": "daily",    "name": "Daily Nutrients",       "label": "Nutrient Health",  "tagline": "Vitamins, omegas, basics",      "icon_path": "M12 2v20m-8-10h16" } }
      ]
    }
  ]
}
{% endschema %}
