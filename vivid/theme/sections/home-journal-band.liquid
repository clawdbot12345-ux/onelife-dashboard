<section class="home-journal-band reveal" id="journal" aria-labelledby="home-journal-heading">
  <div class="container">
    <div class="home-journal-head">
      <div>
        <div class="eyebrow">{{ section.settings.eyebrow }}</div>
        <h2 id="home-journal-heading">{{ section.settings.heading }}</h2>
      </div>
      <p>{{ section.settings.lead }}</p>
    </div>

    {%- liquid
      assign journal_blog = section.settings.blog
      if journal_blog == blank
        assign journal_blog = blogs['vivid-journal']
      endif
      if journal_blog == blank
        assign journal_blog = blogs['journal']
      endif
      if journal_blog == blank
        assign journal_blog = blogs['news']
      endif
    -%}

    <div class="journal-cards journal-cards--articles">
      {%- if journal_blog != blank and journal_blog.articles_count > 0 -%}
        {%- for article in journal_blog.articles limit: 4 -%}
          <a class="journal-card" href="{{ article.url }}">
            <span class="journal-card-media">
              {%- if article.image != blank -%}
                {{ article.image | image_url: width: 900 | image_tag:
                  loading: 'eager',
                  widths: '450,700,900',
                  sizes: '(min-width: 1100px) 22vw, (min-width: 760px) 44vw, 90vw',
                  alt: article.image.alt | default: article.title }}
              {%- else -%}
                {%- case forloop.index -%}
                  {%- when 1 -%}<img src="{{ 'banner-journal.jpg' | asset_url }}" loading="eager" width="1920" height="1080" alt="{{ article.title | escape }}">
                  {%- when 2 -%}<img src="{{ 'physical-trio-wide.jpg' | asset_url }}" loading="eager" width="1024" height="683" alt="{{ article.title | escape }}">
                  {%- when 3 -%}<img src="{{ 'griffonia-bedside.jpg' | asset_url }}" loading="eager" width="1024" height="1536" alt="{{ article.title | escape }}">
                  {%- else -%}<img src="{{ 'allergy-control-lavender.jpg' | asset_url }}" loading="eager" width="853" height="1280" alt="{{ article.title | escape }}">
                {%- endcase -%}
              {%- endif -%}
            </span>
            <span class="journal-card-copy">
              <em>{{ article.published_at | date: '%b %d, %Y' }}</em>
              <strong>{{ article.title }}</strong>
              <small>{{ article.excerpt_or_content | strip_html | truncate: 104 }}</small>
            </span>
          </a>
        {%- endfor -%}
      {%- else -%}
        <a class="journal-card" href="/pages/about">
          <span class="journal-card-media">
            <img src="{{ 'banner-journal.jpg' | asset_url }}" loading="eager" width="1920" height="1080" alt="Vivid Health lifestyle formulations">
          </span>
          <span class="journal-card-copy">
            <em>Brand standard</em>
            <strong>Vivid by nature. Verified by science.</strong>
            <small>How to read exact-dose labels and avoid vague wellness language.</small>
          </span>
        </a>
        <a class="journal-card" href="{{ routes.collections_url }}/bundles">
          <span class="journal-card-media">
            <img src="{{ 'physical-trio-wide.jpg' | asset_url }}" loading="eager" width="1024" height="683" alt="Vivid Health mobility stack products">
          </span>
          <span class="journal-card-copy">
            <em>Stack guide</em>
            <strong>From clutter to calm.</strong>
            <small>When to choose one bottle, when to build a stack, and how 10% stack savings work.</small>
          </span>
        </a>
        <a class="journal-card" href="/products/vivid-health-stay-vivid-griffonia-5-htp-60-capsules">
          <span class="journal-card-media">
            <img src="{{ 'griffonia-bedside.jpg' | asset_url }}" loading="eager" width="1024" height="1536" alt="Vivid Health Griffonia bedside routine">
          </span>
          <span class="journal-card-copy">
            <em>Routine guide</em>
            <strong>Restless nights. Better mornings.</strong>
            <small>How evening support, calmer mood, and next-day focus fit together.</small>
          </span>
        </a>
        <a class="journal-card" href="https://wa.me/27713744910?text=Hi%2C%20I%27d%20like%20help%20choosing%20a%20Vivid%20Health%20routine" target="_blank" rel="noopener">
          <span class="journal-card-media">
            <img src="{{ 'allergy-control-lavender.jpg' | asset_url }}" loading="eager" width="853" height="1280" alt="Vivid Health consultation and daily support">
          </span>
          <span class="journal-card-copy">
            <em>Consult guide</em>
            <strong>Ask before you combine.</strong>
            <small>What to share before stacking supplements, especially around dose and timing.</small>
          </span>
        </a>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Home journal band",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Vivid Journal" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Read before you add another bottle." },
    { "type": "textarea", "id": "lead", "label": "Lead", "default": "Short guides for labels, ingredients, stacks, and daily routines. Built to help customers choose with more confidence before checkout." },
    { "type": "blog", "id": "blog", "label": "Blog source" }
  ],
  "presets": [{ "name": "Home journal band" }]
}
{% endschema %}
