<section class="quiz-head quiz-head--premium" style="background-image:url({{ 'banner-hero-kitchen.jpg' | asset_url }})">
  <div class="container">
    <div class="crumb"><a href="{{ routes.root_url }}">Home</a> / Premium quiz</div>
    <div class="quiz-hero-grid">
      <div>
        <div class="eyebrow" style="color:var(--sage-soft)">Find your formulation</div>
        <h1>{{ section.settings.heading }}</h1>
        <p>{{ section.settings.lede }}</p>
      </div>
      <div class="quiz-hero-proof" aria-label="Quiz benefits">
        <span>4 smart questions</span>
        <span>Specific products</span>
        <span>Direct cart</span>
      </div>
    </div>
  </div>
</section>

<section class="quiz-overlay quiz-overlay--premium">
  <div class="container">
    <div class="quiz-builder" data-vivid-quiz>
      <div class="quiz-builder-main">
        <div class="quiz-step">
          <div class="quiz-step-kicker">Question 1</div>
          <div class="quiz-q">What do you want to support first?</div>
          <div class="quiz-opts quiz-opts--premium">
            <button type="button" class="quiz-opt selected" data-quiz-choice="goal" data-goal-key="gut"><strong>Gut health</strong><span>Cleanse, balance, and digestive support.</span></button>
            <button type="button" class="quiz-opt" data-quiz-choice="goal" data-goal-key="immunity"><strong>Immunity</strong><span>Allergies, defence, and immune rhythm.</span></button>
            <button type="button" class="quiz-opt" data-quiz-choice="goal" data-goal-key="stress"><strong>Sleep & stress</strong><span>Calm, rest, mood, and focus.</span></button>
            <button type="button" class="quiz-opt" data-quiz-choice="goal" data-goal-key="joints"><strong>Joints & mobility</strong><span>Structure, movement, and resilience.</span></button>
            <button type="button" class="quiz-opt" data-quiz-choice="goal" data-goal-key="daily"><strong>Daily nutrients</strong><span>The everyday wellness shelf.</span></button>
            <button type="button" class="quiz-opt" data-quiz-choice="goal" data-goal-key="energy"><strong>Energy</strong><span>Recovery, vitality, and daily fuel.</span></button>
            <button type="button" class="quiz-opt" data-quiz-choice="goal" data-goal-key="women"><strong>Women's health</strong><span>Cycles, hormones, and life-stage support.</span></button>
            <button type="button" class="quiz-opt" data-quiz-choice="goal" data-goal-key="men"><strong>Men's health</strong><span>Prostate, vitality, and daily support.</span></button>
          </div>
        </div>

        <div class="quiz-step">
          <div class="quiz-step-kicker">Question 2</div>
          <div class="quiz-q">Which detail sounds closest?</div>
          <div class="quiz-opts quiz-opts--premium">
            <button type="button" class="quiz-opt selected" data-quiz-choice="signal" data-signal-key="cleanse" data-signal-goals="gut"><strong>Reset or cleanse</strong><span>Gut cleanse, bloating, or a short reset.</span></button>
            <button type="button" class="quiz-opt" data-quiz-choice="signal" data-signal-key="lining" data-signal-goals="gut"><strong>Daily gut repair</strong><span>Lining support, recovery, or gentle daily use.</span></button>
            <button type="button" class="quiz-opt" data-quiz-choice="signal" data-signal-key="seasonal" data-signal-goals="immunity"><strong>Seasonal flare-ups</strong><span>Allergy, histamine, or respiratory seasons.</span></button>
            <button type="button" class="quiz-opt" data-quiz-choice="signal" data-signal-key="daily-immune" data-signal-goals="immunity"><strong>Daily defence</strong><span>Everyday immune support without a big stack.</span></button>
            <button type="button" class="quiz-opt" data-quiz-choice="signal" data-signal-key="sleep" data-signal-goals="stress"><strong>Restless nights</strong><span>Wind-down, sleep rhythm, or evening calm.</span></button>
            <button type="button" class="quiz-opt" data-quiz-choice="signal" data-signal-key="mood" data-signal-goals="stress"><strong>Mood and stress load</strong><span>Calmer thoughts, mood, and nervous-system support.</span></button>
            <button type="button" class="quiz-opt" data-quiz-choice="signal" data-signal-key="bone" data-signal-goals="joints"><strong>Bone structure</strong><span>Mineral matrix, bone density, and long-term support.</span></button>
            <button type="button" class="quiz-opt" data-quiz-choice="signal" data-signal-key="mobility" data-signal-goals="joints"><strong>Joint comfort</strong><span>Movement, connective tissue, and daily mobility.</span></button>
            <button type="button" class="quiz-opt" data-quiz-choice="signal" data-signal-key="cellular" data-signal-goals="energy"><strong>Cellular energy</strong><span>Energy production, stamina, and recovery.</span></button>
            <button type="button" class="quiz-opt" data-quiz-choice="signal" data-signal-key="foundation" data-signal-goals="daily"><strong>Daily foundation</strong><span>Omega, greens, turmeric, or broad nutrition.</span></button>
            <button type="button" class="quiz-opt" data-quiz-choice="signal" data-signal-key="cycle" data-signal-goals="women"><strong>Cycle or hormones</strong><span>PMS, cycle regularity, menopause, or balance.</span></button>
            <button type="button" class="quiz-opt" data-quiz-choice="signal" data-signal-key="prostate" data-signal-goals="men"><strong>Prostate support</strong><span>Men's daily prostate and vitality routine.</span></button>
          </div>
        </div>

        <div class="quiz-step">
          <div class="quiz-step-kicker">Question 3</div>
          <div class="quiz-q">How much routine do you want?</div>
          <div class="quiz-opts quiz-opts--premium quiz-opts--three">
            <button type="button" class="quiz-opt selected" data-quiz-choice="style" data-style-key="single"><strong>One clear bottle</strong><span>Best first step. No over-stacking.</span></button>
            <button type="button" class="quiz-opt" data-quiz-choice="style" data-style-key="pair"><strong>Two-product route</strong><span>A main product plus one logical add-on.</span></button>
            <button type="button" class="quiz-opt" data-quiz-choice="style" data-style-key="stack"><strong>Complete stack</strong><span>Use a curated routine where it makes sense.</span></button>
          </div>
        </div>

        <div class="quiz-step">
          <div class="quiz-step-kicker">Question 4</div>
          <div class="quiz-q">What format fits your day?</div>
          <div class="quiz-opts quiz-opts--premium quiz-opts--three">
            <button type="button" class="quiz-opt selected" data-quiz-choice="format" data-format-key="capsule"><strong>Capsules</strong><span>Measured, portable, easy to repeat.</span></button>
            <button type="button" class="quiz-opt" data-quiz-choice="format" data-format-key="powder"><strong>Powders</strong><span>Flexible dose, smoothie or water.</span></button>
            <button type="button" class="quiz-opt" data-quiz-choice="format" data-format-key="open"><strong>No preference</strong><span>Choose the strongest match.</span></button>
          </div>
        </div>

      </div>

      <aside class="quiz-result-card">
        <div class="quiz-result-label">Your product match</div>
        <h2 data-quiz-result-title>Gut reset starter</h2>
        <p data-quiz-result-desc>Answer the questions and this panel will rebuild around the products that best fit your goal, format, and routine style.</p>

        <div class="quiz-match-summary" data-quiz-summary aria-label="Selected quiz answers"></div>
        <div class="quiz-primary-match" data-quiz-primary aria-label="Primary product recommendation"></div>

        <div class="quiz-result-section">
          <span>First 14 days</span>
          <ol class="quiz-plan" data-quiz-plan></ol>
        </div>

        <div class="quiz-result-section">
          <span>Optional add-ons</span>
          <div class="quiz-product-plan" data-quiz-products aria-label="Recommended supporting products"></div>
        </div>

        <div class="quiz-result-actions">
          <a class="btn btn--forest btn-arrow" href="{{ routes.collections_url }}/gut" data-quiz-result-link>Shop recommended product</a>
          <a class="btn btn--ghost" href="{{ routes.collections_url }}/bundles" data-quiz-stack-link>View matching stack</a>
        </div>

        <div class="quiz-reward">
          <div class="quiz-reward-code">Finished the quiz? Use code <strong>QUIZ5</strong> for 5% off your first order today.</div>
          {% form 'customer', class: 'quiz-email' %}
            <input type="hidden" name="contact[tags]" value="quiz, prelaunch">
            <label class="quiz-email-label" for="quizEmail">Or get your routine by email — and 10% off your first order</label>
            <div class="quiz-email-row">
              <input id="quizEmail" type="email" name="contact[email]" placeholder="your@email.co.za" required aria-label="Email address">
              <button type="submit" class="btn btn--forest">Email my routine</button>
            </div>
            {% if form.posted_successfully? %}<p class="quiz-email-ok">Done — check your inbox. Welcome to Vivid.</p>{% endif %}
            {% if form.errors %}<p class="quiz-email-err">{{ form.errors | default_errors }}</p>{% endif %}
          {% endform %}
        </div>
        <a class="quiz-whatsapp" href="https://wa.me/27713744910?text=Hi%2C%20I%27d%20like%20help%20choosing%20a%20Vivid%20Health%20formulation" target="_blank" rel="noopener">Ask a consultant before you combine products</a>
      </aside>
    </div>
  </div>
</section>

