<section>
  <div class="container">
    <div class="section-head">
      <div>
        <div class="eyebrow">{{ section.settings.eyebrow }}</div>
        <h2 style="margin-top:12px">{{ section.settings.heading }}</h2>
      </div>
      <a href="{{ section.settings.cta_link }}" class="btn btn--ghost btn-arrow">{{ section.settings.cta_label }}</a>
    </div>
    <div class="products-row">
      {%- assign coll = collections[section.settings.collection] -%}
      {%- for product in coll.products limit: section.settings.product_count -%}
        {% render 'product-card', product: product %}
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Featured products",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Most loved" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "The formulations the team keeps reordering." },
    { "type": "collection", "id": "collection", "label": "Collection" },
    { "type": "range", "id": "product_count", "label": "Products to show", "min": 4, "max": 12, "step": 4, "default": 8 },
    { "type": "text", "id": "cta_label", "label": "CTA label", "default": "See all" },
    { "type": "url", "id": "cta_link", "label": "CTA link" }
  ],
  "presets": [{ "name": "Featured products" }]
}
{% endschema %}
