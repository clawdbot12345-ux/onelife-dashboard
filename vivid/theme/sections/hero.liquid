{%- comment -%}
  Hero — full-bleed photo background with overlaid headline, CTAs,
  mini-stats row, and bottom trust strip. Mirrors vivid/index.html .hero.
{%- endcomment -%}

<section class="hero hero--photo" aria-labelledby="hero-heading">
  {%- if section.settings.background_image != blank -%}
    <div class="hero-photo" style="background-image:url('{{ section.settings.background_image | image_url: width: 2400 }}')"></div>
  {%- else -%}
    <div class="hero-photo" style="background-image:url('{{ 'banner-hero-kitchen.jpg' | asset_url }}')"></div>
  {%- endif -%}
  <div class="hero-scrim"></div>
  <div class="container hero-content">
    {%- if section.settings.eyebrow != blank -%}
      <div class="hero-eyebrow">{{ section.settings.eyebrow }}</div>
    {%- endif -%}
    <h1 id="hero-heading">{{ section.settings.heading }}</h1>
    {%- if section.settings.lede != blank -%}
      <p class="hero-lede">{{ section.settings.lede }}</p>
    {%- endif -%}
    <div class="hero-cta">
      {%- if section.settings.cta_primary_label != blank -%}
        <a href="{{ section.settings.cta_primary_link | default: '/collections/all' }}" class="btn btn-arrow">{{ section.settings.cta_primary_label }}</a>
      {%- endif -%}
      {%- if section.settings.cta_secondary_label != blank -%}
        <a href="{{ section.settings.cta_secondary_link | default: '/pages/quiz' }}" class="btn btn--ghost">{{ section.settings.cta_secondary_label }}</a>
      {%- endif -%}
    </div>

    {%- assign stats = section.blocks | where: 'type', 'stat' -%}
    {%- if stats.size > 0 -%}
      <div class="hero-mini">
        {%- for block in stats -%}
          <div class="hero-mini-cell" {{ block.shopify_attributes }}>
            <div class="num">{{ block.settings.value }}</div>
            <div class="lbl">{{ block.settings.label }}</div>
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>

  {%- assign trust = section.blocks | where: 'type', 'trust' -%}
  {%- if trust.size > 0 -%}
    <div class="hero-trust">
      <div class="container hero-trust-inner">
        {%- for block in trust -%}
          <span class="hero-trust-cell" {{ block.shopify_attributes }}>
            {%- case block.settings.icon -%}
              {%- when 'stars' -%}<span class="stars">★★★★★</span> <span class="num">{{ block.settings.value }}</span>
              {%- when 'check' -%}<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12l5 5L20 7"/></svg>
              {%- when 'shield' -%}<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 12l2 2 4-4M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            {%- endcase -%}
            {{ block.settings.text }}
          </span>
        {%- endfor -%}
      </div>
    </div>
  {%- endif -%}
</section>

{% schema %}
{
  "name": "Hero",
  "tag": "section",
  "class": "section-hero",
  "settings": [
    { "type": "image_picker", "id": "background_image",    "label": "Background image (full-bleed)" },
    { "type": "text",         "id": "eyebrow",             "label": "Eyebrow",
      "default": "Botanical precision · Exact-dose labels · South African" },
    { "type": "richtext",     "id": "heading",             "label": "Heading",
      "default": "<p>Vivid by <em>nature.</em><br>Verified by science.</p>" },
    { "type": "textarea",     "id": "lede",                "label": "Lede",
      "default": "Plant-first formulations with the milligrams on the bottle: clean daily support, built for South African routines." },
    { "type": "text",         "id": "cta_primary_label",   "label": "Primary CTA label",   "default": "Shop the range" },
    { "type": "url",          "id": "cta_primary_link",    "label": "Primary CTA link" },
    { "type": "text",         "id": "cta_secondary_label", "label": "Secondary CTA label", "default": "Find your formulation" },
    { "type": "url",          "id": "cta_secondary_link",  "label": "Secondary CTA link" }
  ],
  "blocks": [
    {
      "type": "stat",
      "name": "Mini stat",
      "limit": 4,
      "settings": [
        { "type": "text", "id": "value", "label": "Value", "default": "52" },
        { "type": "text", "id": "label", "label": "Label", "default": "Formulations" }
      ]
    },
    {
      "type": "trust",
      "name": "Trust strip item",
      "limit": 4,
      "settings": [
        { "type": "select", "id": "icon", "label": "Icon",
          "options": [
            { "value": "stars",  "label": "Stars (with rating value)" },
            { "value": "check",  "label": "Checkmark" },
            { "value": "shield", "label": "Shield" }
          ],
          "default": "check" },
        { "type": "text", "id": "value", "label": "Rating value (for Stars icon)", "default": "0" },
        { "type": "text", "id": "text",  "label": "Text",
          "default": "Free shipping over R400" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Hero",
      "blocks": [
        { "type": "stat",  "settings": { "value": "52",   "label": "Formulations" } },
        { "type": "stat",  "settings": { "value": "8",    "label": "Goal-led systems" } },
        { "type": "stat",  "settings": { "value": "0", "label": "proprietary blends" } },
        { "type": "stat",  "settings": { "value": "10%", "label": "stack offer" } },
        { "type": "trust", "settings": { "icon": "check", "text": "Exact active doses listed" } },
        { "type": "trust", "settings": { "icon": "check",  "text": "Free shipping over R400" } },
        { "type": "trust", "settings": { "icon": "shield", "text": "30-day money-back" } }
      ]
    }
  ]
}
{% endschema %}
