{%- comment -%}
  Header — sticky paper-translucent nav with logo, link menu,
  search/account/cart icons, mobile burger + slide-in drawer.
{%- endcomment -%}

<nav class="nav" aria-label="Primary">
  <div class="nav-inner">
    <a href="{{ routes.root_url }}" class="brand" aria-label="{{ shop.name }} home">
      <img
        src="{{ 'vivid-logo-wordmark.svg' | asset_url }}"
        class="brand-logo brand-logo--svg"
        width="640"
        height="200"
        alt="{{ shop.name }}"
        loading="eager"
      >
    </a>
    <div class="nav-links">
      <a href="{{ routes.collections_url }}/all-formulations">Shop</a>
      <a href="{{ routes.root_url }}#systems">Systems</a>
      <a href="{{ routes.collections_url }}/bundles">Stacks</a>
      <a href="/pages/quiz">Find your formulation</a>
      <a href="{{ routes.root_url }}#journal">Journal</a>
      <a href="/pages/our-approach">Our approach</a>
      <a href="/pages/about">About</a>
    </div>
    <div class="nav-actions">
      <a href="{{ routes.search_url }}" class="icon-btn" aria-label="Search">
        <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><circle cx="11" cy="11" r="7"/><path d="M21 21l-4.3-4.3"/></svg>
      </a>
      <a href="{{ routes.account_url }}" class="icon-btn" aria-label="Account">
        <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><circle cx="12" cy="8" r="4"/><path d="M4 21c0-4.4 3.6-8 8-8s8 3.6 8 8"/></svg>
      </a>
      <button class="icon-btn cart-pip" id="cartBtn" type="button" aria-label="Cart ({{ cart.item_count }} items)" data-count="{{ cart.item_count }}">
        <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><path d="M3 6h2l2.7 12.5a2 2 0 0 0 2 1.5h8.6a2 2 0 0 0 2-1.5L22 9H6"/></svg>
      </button>
      <button class="nav-burger" id="navBurger" type="button" aria-label="Open menu" aria-controls="mobnav">
        <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><path d="M4 7h16M4 12h16M4 17h16"/></svg>
      </button>
    </div>
  </div>
</nav>


{% schema %}
{
  "name": "Header",
  "settings": [
    { "type": "image_picker", "id": "logo", "label": "Logo (dark, for cream nav)" },
    { "type": "link_list",    "id": "menu", "label": "Primary menu", "default": "main-menu" }
  ]
}
{% endschema %}
