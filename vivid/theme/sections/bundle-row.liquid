<section>
  <div class="container">
    <div class="section-head">
      <div>
        <div class="eyebrow">{{ section.settings.eyebrow }}</div>
        <h2 style="margin-top:12px">{{ section.settings.heading }}</h2>
      </div>
      <p class="lead">{{ section.settings.lead }}</p>
    </div>
    <div class="bundles">
      {%- assign coll = section.settings.collection -%}
      {%- if coll == blank or coll.products_count == 0 -%}
        {%- assign coll = collections['bundles'] -%}
      {%- endif -%}
      {%- for product in coll.products limit: 3 -%}
        <a href="{{ product.url }}" class="bundle">
          <div class="bundle-media" style="background:radial-gradient(circle at 50% 40%,var(--paper),var(--cream) 80%)">
            {%- if product.metafields.vivid.save != blank -%}
              <span class="bundle-tag">Save R{{ product.metafields.vivid.save }}</span>
            {%- endif -%}
            {%- if product.featured_image != blank -%}
              {{ product.featured_image | image_url: width: 800 | image_tag: loading: 'lazy', widths: '300,600,900,1200', sizes: '(min-width: 880px) 33vw, 100vw', alt: product.title }}
            {%- else -%}
              {%- assign fallback_asset = 'physical-trio.jpg' -%}
              {%- assign fallback_width = 1024 -%}
              {%- assign fallback_height = 1536 -%}
              {%- if product.handle contains 'allergy' -%}
                {%- assign fallback_asset = 'banner-group-allergy.jpg' -%}
                {%- assign fallback_width = 1920 -%}
                {%- assign fallback_height = 1080 -%}
              {%- elsif product.handle contains 'rest' or product.handle contains 'focus' -%}
                {%- assign fallback_asset = 'griffonia-bedside.jpg' -%}
              {%- endif -%}
              <img src="{{ fallback_asset | asset_url }}" loading="lazy" width="{{ fallback_width }}" height="{{ fallback_height }}" alt="{{ product.title | escape }}">
            {%- endif -%}
          </div>
          <div class="bundle-body">
            <div class="bundle-name">{{ product.title }}</div>
            <p style="font-size:14px;color:var(--ink-soft);line-height:1.5;margin:0 0 16px">{{ product.description | strip_html | truncate: 140 }}</p>
            <div style="display:flex;justify-content:space-between;align-items:center">
              <div>
                <span style="font-family:var(--font-display);font-size:22px">{{ product.price | money }}</span>
              </div>
              <span class="btn btn--ghost" style="padding:8px 14px;font-size:12px">Shop stack →</span>
            </div>
          </div>
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Bundle row",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Curated stacks" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Three bundles, built for outcomes." },
    { "type": "textarea", "id": "lead", "label": "Lead", "default": "Pre-paired formulations that work together. Saves you R110–R150 vs buying separately." },
    { "type": "collection", "id": "collection", "label": "Bundles collection" }
  ],
  "presets": [{ "name": "Bundle row" }]
}
{% endschema %}
