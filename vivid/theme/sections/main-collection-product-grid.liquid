{%- assign banner_asset = blank -%}
{%- case collection.handle -%}
  {%- when 'gut' -%}{%- assign banner_asset = 'banner-gut.jpg' -%}
  {%- when 'immunity' -%}{%- assign banner_asset = 'banner-immunity.jpg' -%}
  {%- when 'energy' -%}{%- assign banner_asset = 'banner-energy.jpg' -%}
  {%- when 'stress' -%}{%- assign banner_asset = 'banner-stress.jpg' -%}
  {%- when 'joints' -%}{%- assign banner_asset = 'banner-joints.jpg' -%}
  {%- when 'women' -%}{%- assign banner_asset = 'banner-women.jpg' -%}
  {%- when 'men' -%}{%- assign banner_asset = 'banner-men.jpg' -%}
  {%- when 'daily' -%}{%- assign banner_asset = 'banner-daily.jpg' -%}
  {%- when 'all-formulations' -%}{%- assign banner_asset = 'banner-journal.jpg' -%}
  {%- when 'bestsellers' -%}{%- assign banner_asset = 'banner-journal.jpg' -%}
  {%- when 'bundles' -%}{%- assign banner_asset = 'banner-group-sleep.jpg' -%}
{%- endcase -%}

<div class="collection-head{% if banner_asset != blank %} collection-head--banner{% endif %}"{% if banner_asset != blank %} style="--banner:url('{{ banner_asset | asset_url }}')"{% endif %}>
  {%- if banner_asset != blank -%}
    <div class="collection-bg"></div>
  {%- endif -%}
  <div class="container">
    <div class="crumb" style="font-size:12px;letter-spacing:.12em;text-transform:uppercase;margin-bottom:16px"><a href="{{ routes.root_url }}" style="font-weight:600">Home</a> · {{ collection.title }}</div>
    <h1>{{ collection.title }}</h1>
    {%- if collection.description != blank -%}
      <div class="collection-head-copy" data-collection-lead>{{ collection.description }}</div>
    {%- endif -%}
  </div>
</div>

<div class="container">
  {%- liquid
    assign active_filter = collection.handle
    if active_filter == 'all-formulations' or active_filter == blank
      assign active_filter = 'all'
    endif
    assign display_collection = collections['all-formulations']
    if display_collection == blank or display_collection.products_count == 0
      assign display_collection = collections.all
    endif
  -%}
  {%- paginate display_collection.products by 250 -%}
    <div class="shop-toolbar" data-collection-filter data-active-filter="{{ active_filter }}">
      <div class="chip-row chip-row--premium" aria-label="Shop by Vivid routine">
        <a href="{{ routes.collections_url }}/all-formulations" class="chip{% if active_filter == 'all' %} is-active{% endif %}" data-filter-goal="all" data-filter-banner="{{ 'banner-journal.jpg' | asset_url }}">
          All formulations <span class="chip-ct">{{ collections['all-formulations'].products_count | default: display_collection.products_count }}</span>
        </a>
        <a href="{{ routes.collections_url }}/bundles" class="chip chip--stack{% if active_filter == 'bundles' %} is-active{% endif %}" data-filter-goal="bundles" data-filter-banner="{{ 'banner-group-sleep.jpg' | asset_url }}">
          Curated stacks <span class="chip-ct">10% off</span>
        </a>
        <a href="{{ routes.collections_url }}/gut" class="chip{% if active_filter == 'gut' %} is-active{% endif %}" data-filter-goal="gut" data-filter-banner="{{ 'banner-gut.jpg' | asset_url }}">
          Gut <span class="chip-ct">{{ collections['gut'].products_count }}</span>
        </a>
        <a href="{{ routes.collections_url }}/immunity" class="chip{% if active_filter == 'immunity' %} is-active{% endif %}" data-filter-goal="immunity" data-filter-banner="{{ 'banner-immunity.jpg' | asset_url }}">
          Immunity <span class="chip-ct">{{ collections['immunity'].products_count }}</span>
        </a>
        <a href="{{ routes.collections_url }}/stress" class="chip{% if active_filter == 'stress' %} is-active{% endif %}" data-filter-goal="stress" data-filter-banner="{{ 'banner-stress.jpg' | asset_url }}">
          Sleep & stress <span class="chip-ct">{{ collections['stress'].products_count }}</span>
        </a>
        <a href="{{ routes.collections_url }}/joints" class="chip{% if active_filter == 'joints' %} is-active{% endif %}" data-filter-goal="joints" data-filter-banner="{{ 'banner-joints.jpg' | asset_url }}">
          Joints & mobility <span class="chip-ct">{{ collections['joints'].products_count }}</span>
        </a>
        <a href="{{ routes.collections_url }}/energy" class="chip{% if active_filter == 'energy' %} is-active{% endif %}" data-filter-goal="energy" data-filter-banner="{{ 'banner-energy.jpg' | asset_url }}">
          Energy <span class="chip-ct">{{ collections['energy'].products_count }}</span>
        </a>
        <a href="{{ routes.collections_url }}/women" class="chip{% if active_filter == 'women' %} is-active{% endif %}" data-filter-goal="women" data-filter-banner="{{ 'banner-women.jpg' | asset_url }}">
          Women's <span class="chip-ct">{{ collections['women'].products_count }}</span>
        </a>
        <a href="{{ routes.collections_url }}/men" class="chip{% if active_filter == 'men' %} is-active{% endif %}" data-filter-goal="men" data-filter-banner="{{ 'banner-men.jpg' | asset_url }}">
          Men's <span class="chip-ct">{{ collections['men'].products_count }}</span>
        </a>
        <a href="{{ routes.collections_url }}/daily" class="chip{% if active_filter == 'daily' %} is-active{% endif %}" data-filter-goal="daily" data-filter-banner="{{ 'banner-daily.jpg' | asset_url }}">
          Daily nutrients <span class="chip-ct">{{ collections['daily'].products_count }}</span>
        </a>
      </div>
      <div class="shop-sort">
        <span class="sort-lbl">Sort</span>
        <select data-filter-sort>
          <option value="featured">Featured</option>
          <option value="title-ascending">Alphabetically, A-Z</option>
          <option value="price-ascending">Price, low to high</option>
          <option value="price-descending">Price, high to low</option>
        </select>
      </div>
    </div>
    <div class="shop-meta">
      <span><span data-filter-count>{{ display_collection.products_count }}</span> products</span>
      <a class="shop-meta-clear" href="/pages/quiz">Not sure? Take the quiz</a>
    </div>
    <div class="shop-promo-strip" aria-label="Vivid shopping help">
      <a href="/pages/quiz">
        <strong>Find your formulation</strong>
        <span>A premium quiz for goal, routine, and format.</span>
      </a>
      <a href="{{ routes.collections_url }}/bundles">
        <strong>Build a stack</strong>
        <span>Outcome-led routines with a 10% stack offer.</span>
      </a>
      <a href="https://wa.me/27713744910?text=Hi%2C%20I%27d%20like%20a%20free%20Vivid%20Health%20consultation" target="_blank" rel="noopener">
        <strong>Free consultation</strong>
        <span>Ask a consultant before you combine products.</span>
      </a>
    </div>
    <div class="products-row products-row--shop products-row--3col">
      {%- for product in display_collection.products -%}
        {% render 'product-card', product: product %}
      {%- endfor -%}
      {% render 'vivid-stack-card',
        handle: 'vivid-allergy-stack-complete-allergy-support-bundle',
        title: 'Vivid Allergy Stack',
        kicker: 'Immune health · 3-product stack',
        copy: 'Allergy Control, Quercetin Complex, and Buffered C for seasonal support without random bottle collecting.',
        price_cents: 59472,
        image: 'banner-group-allergy.jpg',
        position: 'center'
      %}
      {% render 'vivid-stack-card',
        handle: 'vivid-bone-joint-pack-complete-skeletal-support-bundle',
        title: 'Vivid Bone & Joint Pack',
        kicker: 'Joints & mobility · 3-product stack',
        copy: 'Bone Supreme, MSM, and Flexijoint paired for structure, connective tissue, and daily movement support.',
        price_cents: 74266,
        image: 'physical-trio-wide.jpg',
        position: 'center'
      %}
      {% render 'vivid-stack-card',
        handle: 'vivid-rest-focus-stack-sleep-calm-and-mental-clarity-bundle',
        title: 'Vivid Rest & Focus Stack',
        kicker: 'Sleep & stress · 3-product stack',
        copy: 'Griffonia, Tranquil, and GABA arranged into a calmer evening routine with sharper next-day intent.',
        price_cents: 58767,
        image: 'banner-group-sleep.jpg',
        position: 'center'
      %}
    </div>
    {%- if paginate.pages > 1 -%}
      <div style="margin-top:48px;display:flex;justify-content:center;gap:8px">
        {{ paginate | default_pagination }}
      </div>
    {%- endif -%}
  {%- endpaginate -%}
</div>

{% schema %}
{
  "name": "Collection grid",
  "settings": [
    { "type": "range", "id": "products_per_page", "min": 12, "max": 48, "step": 4, "default": 24, "label": "Products per page" }
  ]
}
{% endschema %}
