<!doctype html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover">
  <meta name="theme-color" content="{{ settings.color_forest_deep | default: '#0C2117' }}">
  <link rel="canonical" href="{{ canonical_url }}">

  {%- if settings.favicon != blank -%}
    <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32 }}">
  {%- endif -%}

  <title>{{ shop.name }} — Coming soon</title>
  <meta name="description" content="{{ shop.name }} — plant-first supplements made in Centurion. Dose-stated, vegetable capsules, every milligram on every label. Launching soon.">
  <meta property="og:title" content="{{ shop.name }} — Coming soon">
  <meta property="og:description" content="Plant-first formulations with the milligrams on the bottle. Launching soon.">
  <meta property="og:type" content="website">

  <link rel="preconnect" href="https://cdn.shopify.com" crossorigin>
  {{ settings.font_display | font_face: font_display: 'swap' }}
  {{ settings.font_body | font_face: font_display: 'swap' }}
  {{ 'base.css' | asset_url | stylesheet_tag }}

  {% style %}
    body{background:var(--forest-deep);color:var(--paper);min-height:100vh;display:flex;flex-direction:column}
    .pw-shell{position:relative;min-height:100vh;display:flex;flex-direction:column;overflow:hidden}
    .pw-bg{position:absolute;inset:0;background-image:url('{{ 'banner-hero-evening.jpg' | asset_url }}');background-size:cover;background-position:center;z-index:0;filter:saturate(.85)}
    .pw-scrim{position:absolute;inset:0;background:linear-gradient(180deg, rgba(11,22,16,.55) 0%, rgba(11,22,16,.30) 35%, rgba(11,22,16,.92) 100%), linear-gradient(90deg, rgba(11,22,16,.45) 0%, rgba(11,22,16,.10) 50%, rgba(11,22,16,.45) 100%);z-index:1}
    .pw-grain{position:absolute;inset:0;background-image:url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='220' height='220' viewBox='0 0 220 220'><filter id='n'><feTurbulence type='fractalNoise' baseFrequency='.85' numOctaves='2' stitchTiles='stitch'/><feColorMatrix values='0 0 0 0 0.08 0 0 0 0 0.06 0 0 0 0 0.04 0 0 0 .25 0'/></filter><rect width='100%25' height='100%25' filter='url(%23n)' opacity='.5'/></svg>");opacity:.4;mix-blend-mode:multiply;pointer-events:none;z-index:2}
    .pw-inner{position:relative;z-index:3;flex:1;display:flex;flex-direction:column;padding:var(--s-6) 28px}
    .pw-brand{display:flex;align-items:center;gap:14px}
    .pw-brand .brand-wordmark{color:var(--paper)}
    .pw-brand .brand-wordmark span{font-family:var(--font-sans);font-weight:900;font-size:22px;letter-spacing:.08em}
    .pw-brand .brand-wordmark small{font-size:7px;letter-spacing:.5em;color:var(--ochre)}
    .pw-card{margin:auto;max-width:680px;width:100%;text-align:center;padding:var(--s-6) 0}
    .pw-eyebrow{font-family:var(--font-sans);font-size:11px;letter-spacing:.28em;text-transform:uppercase;color:var(--sage);font-weight:700;margin-bottom:var(--s-5);display:flex;justify-content:center;gap:14px;align-items:center}
    .pw-eyebrow::before,.pw-eyebrow::after{content:"";width:36px;height:1px;background:rgba(244,236,219,.45)}
    .pw-card h1{font-family:var(--font-display);color:var(--paper);font-size:clamp(44px,7vw,96px);line-height:.95;letter-spacing:-.03em;margin:0 0 var(--s-5);text-shadow:0 2px 24px rgba(0,0,0,.4);font-variation-settings:"opsz" 144,"SOFT" 30}
    .pw-card h1 em{color:var(--sage-soft);font-style:italic;font-weight:300;font-variation-settings:"SOFT" 100}
    .pw-card .pw-lede{font-size:18px;color:rgba(244,236,219,.86);line-height:1.6;max-width:54ch;margin:0 auto var(--s-6);text-shadow:0 1px 12px rgba(0,0,0,.3)}
    .pw-promises{display:grid;grid-template-columns:repeat(3,1fr);gap:var(--s-5);max-width:720px;margin:var(--s-6) auto var(--s-7);padding:var(--s-5) 0;border-top:1px solid rgba(244,236,219,.18);border-bottom:1px solid rgba(244,236,219,.18)}
    .pw-promise{text-align:center}
    .pw-promise-num{font-family:var(--font-display);font-size:24px;color:var(--ochre);font-style:italic;font-weight:300;line-height:1;margin-bottom:8px;font-variation-settings:"opsz" 144,"SOFT" 100}
    .pw-promise-text{font-family:var(--font-display);font-size:15px;line-height:1.3;color:var(--paper);font-variation-settings:"opsz" 96,"SOFT" 50}
    .pw-promise-text em{font-style:italic;color:var(--sage);font-weight:300}
    .pw-form{max-width:520px;margin:0 auto}
    .pw-form label{display:block;font-size:11px;letter-spacing:.2em;text-transform:uppercase;color:var(--sage);font-weight:600;margin-bottom:var(--s-3)}
    .pw-form-row{display:flex;gap:10px}
    .pw-form input[type=email]{flex:1;background:rgba(244,236,219,.06);border:1px solid rgba(244,236,219,.28);color:var(--paper);padding:16px 22px;border-radius:var(--r-pill);font-size:14px;font-family:inherit;outline:none;transition:.15s}
    .pw-form input::placeholder{color:rgba(244,236,219,.45)}
    .pw-form input:focus{border-color:var(--ochre);background:rgba(244,236,219,.10)}
    .pw-form button{padding:16px 28px;border-radius:var(--r-pill);background:var(--clay);color:var(--paper);font-size:13px;font-weight:600;letter-spacing:.04em;border:1px solid var(--clay);cursor:pointer;font-family:inherit;transition:.15s}
    .pw-form button:hover{background:var(--clay-deep);border-color:var(--clay-deep);transform:translateY(-1px)}
    .pw-tiny{font-size:11px;color:rgba(244,236,219,.5);margin-top:var(--s-4);letter-spacing:.12em;text-transform:uppercase}
    .pw-feedback{margin-top:var(--s-4);padding:14px 18px;border-radius:var(--r-md);background:rgba(157,179,154,.14);color:var(--sage-soft);font-size:14px}
    .pw-feedback--error{background:rgba(163,51,36,.14);color:#F2B6A8}
    .pw-foot{padding-top:var(--s-7);border-top:1px solid rgba(244,236,219,.12);margin-top:var(--s-7);display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:var(--s-4);font-size:11px;letter-spacing:.14em;text-transform:uppercase;color:rgba(244,236,219,.45);font-weight:600}
    .pw-foot a{color:rgba(244,236,219,.7);transition:.15s}
    .pw-foot a:hover{color:var(--paper)}
    .pw-staff{margin-top:var(--s-5);text-align:center;font-size:12px;color:rgba(244,236,219,.45);letter-spacing:.08em}
    .pw-staff a{color:var(--sage-soft);text-decoration:underline;text-underline-offset:3px}
    .pw-have-password{margin-top:var(--s-5);text-align:center;font-size:12px;color:rgba(244,236,219,.45);letter-spacing:.06em}
    .pw-have-password summary{cursor:pointer;display:inline-block;padding:8px 14px;border:1px solid rgba(244,236,219,.18);border-radius:var(--r-pill);transition:.15s;list-style:none}
    .pw-have-password summary::-webkit-details-marker{display:none}
    .pw-have-password summary:hover{color:var(--paper);border-color:rgba(244,236,219,.4)}
    .pw-have-password[open] summary{color:var(--paper);border-color:rgba(244,236,219,.4)}
    .pw-have-password-form{margin-top:var(--s-4);padding:var(--s-4) var(--s-5);background:rgba(11,22,16,.4);border:1px solid rgba(244,236,219,.12);border-radius:var(--r-md)}
    .pw-have-password-form input[type=password]{background:rgba(244,236,219,.06);border:1px solid rgba(244,236,219,.22);color:var(--paper);padding:10px 14px;border-radius:var(--r-sm);font-size:13px;font-family:inherit;margin-right:6px}
    .pw-have-password-form input[type=submit],.pw-have-password-form button{padding:10px 16px;border-radius:var(--r-sm);background:var(--paper);color:var(--ink);font-size:12px;font-weight:600;letter-spacing:.04em;border:0;cursor:pointer;font-family:inherit}
    @media (max-width:700px){
      .pw-promises{grid-template-columns:1fr;gap:var(--s-4);padding:var(--s-4) 0}
      .pw-form-row{flex-direction:column}
      .pw-foot{justify-content:center;text-align:center}
    }
  {% endstyle %}
</head>
<body class="template-password">
  <div class="pw-shell">
    <div class="pw-bg"></div>
    <div class="pw-scrim"></div>
    <div class="pw-grain"></div>

    <div class="pw-inner container">
      <header class="pw-brand">
        <span class="brand-wordmark"><span>VIVID</span><small>HEALTH</small></span>
      </header>

      <div class="pw-card">
        <div class="pw-eyebrow">Coming soon · Centurion, South Africa</div>
        <h1>Plant-first.<br>Dose-stated.<br><em>Made in Centurion.</em></h1>
        <p class="pw-lede">{{ shop_name | default: shop.name }} is the formulation arm of Onelife Health, going live soon. Every milligram on every label. Vegetable capsules. Nothing imported in bulk and relabelled.</p>

        <div class="pw-promises" aria-hidden="true">
          <div class="pw-promise">
            <div class="pw-promise-num">01</div>
            <div class="pw-promise-text">We put the dose <em>on the bottle.</em></div>
          </div>
          <div class="pw-promise">
            <div class="pw-promise-num">02</div>
            <div class="pw-promise-text">Plants <em>first.</em> Always.</div>
          </div>
          <div class="pw-promise">
            <div class="pw-promise-num">03</div>
            <div class="pw-promise-text">One bottle, <em>one job.</em></div>
          </div>
        </div>

        {% form 'customer', class: 'pw-form' %}
          <input type="hidden" name="contact[tags]" value="pre-launch, password-page">
          <label for="pw-email">Get the launch announcement (and 10% off your first order)</label>
          <div class="pw-form-row">
            <input id="pw-email" type="email" name="contact[email]" placeholder="your@email.co.za" required autocomplete="email" aria-label="Email address">
            <button type="submit">Notify me</button>
          </div>
          {%- if form.posted_successfully? -%}
            <p class="pw-feedback">Thanks. You'll be the first to hear when we open the doors.</p>
          {%- endif -%}
          {%- if form.errors -%}
            <p class="pw-feedback pw-feedback--error">Couldn't sign you up — {{ form.errors.translated_fields.email }} {{ form.errors.messages.email }}</p>
          {%- endif -%}
          <p class="pw-tiny">No spam · Unsubscribe in one click · POPIA-compliant</p>
        {% endform %}

        <div class="pw-staff">
          Are you on the team? <a href="/admin">Sign in to the Vivid admin →</a>
        </div>

        <details class="pw-have-password">
          <summary>Have a password?</summary>
          <div class="pw-have-password-form">
            {{ content_for_layout }}
          </div>
        </details>
      </div>

      <footer class="pw-foot">
        <div>© {{ 'now' | date: '%Y' }} Vivid Health · Operated by Interlife Wholesalers (Pty) Ltd</div>
        <div>
          <a href="https://onelife.co.za" target="_blank" rel="noopener">Shop Onelife</a> ·
          <a href="https://wa.me/27713744910" target="_blank" rel="noopener">WhatsApp a consultant</a>
        </div>
      </footer>
    </div>
  </div>

  {{ content_for_header }}
</body>
</html>
