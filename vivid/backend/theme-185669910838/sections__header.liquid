{%- if settings.predictive_search_enabled -%}
  <script>
    window.olLoadPredictiveSearch = window.olLoadPredictiveSearch || function () {
      if (window.__olPredictiveSearchPromise) return window.__olPredictiveSearchPromise;
      if (!window.OnelifeLazy) return Promise.resolve();
      window.__olPredictiveSearchPromise = window.OnelifeLazy.loadScript('{{ 'predictive-search.js' | asset_url }}');
      return window.__olPredictiveSearchPromise;
    };

    document.addEventListener('focusin', function (event) {
      if (event.target.closest('predictive-search')) window.olLoadPredictiveSearch();
    });

    document.addEventListener('pointerdown', function (event) {
      if (event.target.closest('.header__icon--search, .header__search')) window.olLoadPredictiveSearch();
    }, { passive: true });
  </script>
{%- endif -%}

