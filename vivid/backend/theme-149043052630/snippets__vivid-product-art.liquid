  assign vivid_art_alt = alt | default: product.title
  assign vivid_art_class = class | default: ''
  assign vivid_art_loading = loading | default: 'lazy'
  assign vivid_art_width = width | default: 1200
  assign vivid_art_height = height | default: 1500
  assign vivid_art_image_width = image_width | default: 1200
  assign vivid_art_sizes = sizes | default: '(min-width: 1100px) 25vw, (min-width: 780px) 33vw, 50vw'
  assign vivid_art_id = id | default: ''
  assign vivid_art_mode = mode | default: 'image'
  assign vivid_art_fetchpriority = fetchpriority | default: ''
-%}

{%- if vivid_art_mode == 'src' -%}
  {%- if vivid_art_asset != blank -%}{{ vivid_art_asset | asset_url }}{%- endif -%}
{%- elsif vivid_art_asset != blank -%}
  <img
    src="{{ vivid_art_asset | asset_url }}"
    {% if vivid_art_id != blank %}id="{{ vivid_art_id | escape }}"{% endif %}
    loading="{{ vivid_art_loading }}"
    {% if vivid_art_fetchpriority != blank %}fetchpriority="{{ vivid_art_fetchpriority }}"{% endif %}
    decoding="async"
    width="{{ vivid_art_width }}"
    height="{{ vivid_art_height }}"
    alt="{{ vivid_art_alt | escape }}"
    class="{{ vivid_art_class }} vivid-art vivid-art--generated vivid-art--{{ vivid_art_layout }}"
  >
{%- elsif product.featured_image != blank -%}
  {%- assign vivid_fallback_class = vivid_art_class | append: ' vivid-art vivid-art--fallback' -%}
  {{ product.featured_image | image_url: width: vivid_art_image_width | image_tag:
      id: vivid_art_id,
      loading: vivid_art_loading,
      widths: '300,600,900,1200,1600',
      sizes: vivid_art_sizes,
      alt: vivid_art_alt,
      class: vivid_fallback_class }}
{%- endif -%}
