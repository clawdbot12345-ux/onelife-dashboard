{%- liquid
  assign stack_handle = handle | default: ''
  assign stack_title = title | default: 'Vivid stack'
  assign stack_kicker = kicker | default: 'Curated stack'
  assign stack_copy = copy | default: 'Pre-paired Vivid routine with the 10% stack offer.'
  assign stack_price = price_cents | default: 0
  assign stack_size = size | default: '3-product stack'
  assign stack_image = image | default: 'banner-group-bestsellers.jpg'
  assign stack_position = position | default: 'center'
-%}

<a
  href="/products/{{ stack_handle }}"
  class="card card--stack-card"
  data-goal="bundles"
  data-title="{{ stack_title | escape }}"
  data-price="{{ stack_price }}"
  aria-label="{{ stack_title | escape }}"
>
  <div class="card-media card-media--stack">
    <div class="card-badge">
      <span class="pill pill--dark">10% off</span>
    </div>
    <img
      src="{{ stack_image | asset_url }}"
      loading="lazy"
      decoding="async"
      width="1200"
      height="800"
      alt="{{ stack_title | escape }}"
      class="card-media__image vivid-art vivid-art--generated vivid-art--wide"
      style="object-position:{{ stack_position | escape }};"
    >
  </div>
  <div class="card-body">
    <div class="card-cat">{{ stack_kicker }}</div>
    <div class="card-name">{{ stack_title }}</div>
    <div class="card-bench">{{ stack_copy }}</div>
    <div class="card-meta">
      <div class="card-price">{{ stack_price | money_without_trailing_zeros }}</div>
      <div class="card-form">{{ stack_size }}</div>
    </div>
  </div>
</a>
