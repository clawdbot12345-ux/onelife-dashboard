{%- assign current_variant = product.selected_or_first_available_variant -%}
<div class="container pdp">
  <div class="crumb" style="font-size:12px;letter-spacing:.12em;text-transform:uppercase;color:var(--ink-soft);margin-bottom:24px">
    <a href="{{ routes.root_url }}" style="color:var(--forest);font-weight:600">Home</a> ·
    <a href="{{ routes.collections_url }}" style="color:var(--forest);font-weight:600">Shop</a> ·
    {{ product.title }}
  </div>
  <div class="pdp-grid">
    <div class="pdp-gallery">
      <div class="pdp-main-img">
        {% render 'vivid-product-art',
          product: product,
          class: 'pdp-main-img__image',
          loading: 'eager',
          sizes: '(min-width: 880px) 50vw, 100vw',
          width: 1200,
          height: 1500,
          image_width: 1200,
          id: 'pdpMainImg',
          alt: product.title %}
      </div>
      {%- capture vivid_generated_src -%}{% render 'vivid-product-art', product: product, mode: 'src' %}{%- endcapture -%}
      {%- assign vivid_generated_src = vivid_generated_src | strip -%}
      <div class="pdp-thumbs">
        {%- if vivid_generated_src != blank -%}
          <button class="pdp-thumb js-thumb active" data-src="{{ vivid_generated_src }}">
            <img src="{{ vivid_generated_src }}" loading="lazy" width="200" height="250" alt="{{ product.title | escape }}">
          </button>
        {%- else -%}
          {%- for img in product.images limit: 6 -%}
            <button class="pdp-thumb js-thumb {% if forloop.first %}active{% endif %}" data-src="{{ img | image_url: width: 1200 }}">
              {{ img | image_url: width: 200 | image_tag: loading: 'lazy', widths: '100,200,300', alt: '' }}
            </button>
          {%- endfor -%}
        {%- endif -%}
      </div>
    </div>
    <div>
      <div class="pdp-cat" style="font-size:12px;letter-spacing:.16em;text-transform:uppercase;color:var(--moss);font-weight:600;margin-bottom:12px">
        {{ product.type }}
      </div>
      <h1>{{ product.title | split: ' - ' | last }}</h1>
      <p style="font-size:16px;color:var(--ink-soft);line-height:1.55;margin-bottom:24px;max-width:48ch">{{ product.metafields.vivid.bench | default: product.description | strip_html | truncate: 180 }}</p>
      <div style="display:flex;align-items:center;gap:10px;margin-bottom:24px;font-size:13px;color:var(--ink-soft)">
        <span class="pill pill--green">Exact-dose label</span> Clear daily routine
      </div>
      <div class="pdp-price-row">
        <div class="pdp-price">{{ current_variant.price | money }}</div>
        <div style="font-size:12px;color:var(--ink-soft)">incl. VAT</div>
        {%- unless current_variant.available -%}
          <span class="pill pill--alert">Currently sold out</span>
        {%- endunless -%}
      </div>

      {%- unless product.has_only_default_variant -%}
        <div style="display:flex;gap:10px;margin-bottom:16px;flex-wrap:wrap">
          {%- for variant in product.variants -%}
            <button class="opt {% if variant.id == current_variant.id %}active{% endif %}" data-variant-id="{{ variant.id }}">
              {{ variant.title }} — {{ variant.price | money }}
            </button>
          {%- endfor -%}
        </div>
      {%- endunless -%}

      <div class="add-row">
        <div class="qty">
          <button class="js-qty-step" data-step="-1">−</button>
          <input id="qty" type="text" value="1">
          <button class="js-qty-step" data-step="1">+</button>
        </div>
        <button class="btn btn--forest btn--block js-add-to-cart" data-variant-id="{{ current_variant.id }}" {% unless current_variant.available %}disabled{% endunless %}>
          {%- if current_variant.available -%}
            Add to basket — {{ current_variant.price | money }}
          {%- else -%}
            Notify me when back
          {%- endif -%}
        </button>
      </div>

      <ul class="bullets">
        {%- assign benefits = product.metafields.vivid.benefits.value -%}
        {%- if benefits != blank -%}
          {%- for b in benefits -%}<li>{{ b }}</li>{%- endfor -%}
        {%- else -%}
          <li>{{ product.description | strip_html | truncate: 120 }}</li>
        {%- endif -%}
      </ul>

      <div class="tabs">
        <div class="tab-head">
          <button class="js-tab active" data-tab="benefits">Benefits</button>
          <button class="js-tab" data-tab="ingredients">Ingredients & dose</button>
          <button class="js-tab" data-tab="how">How to take</button>
          <button class="js-tab" data-tab="faq">FAQ</button>
        </div>
        <div class="tab-body active" data-tab="benefits">
          {{ product.description }}
        </div>
        <div class="tab-body" data-tab="ingredients">
          <h4>Per dose</h4>
          <p>{{ product.metafields.vivid.dose | default: 'See bottle for full ingredient breakdown.' }}</p>
        </div>
        <div class="tab-body" data-tab="how">
          <h4>Daily routine</h4>
          <p>{{ product.metafields.vivid.how_to_take | default: 'Take 1–3 capsules daily with water, ideally with a meal, or as directed by a qualified healthcare practitioner.' }}</p>
          <p style="margin-top:14px;font-size:13px;color:var(--ink-soft)"><strong>Storage:</strong> Below 25°C, in a cool, dry place.</p>
        </div>
        <div class="tab-body" data-tab="faq">
          <h4>Common questions</h4>
          <p><strong>Is this safe in pregnancy?</strong><br>Consult your healthcare provider before use during pregnancy or while breastfeeding.</p>
        </div>
      </div>
    </div>
  </div>

  {%- assign related_handle = blank -%}
  {%- for tag in product.tags -%}
    {%- if tag contains 'goal:' -%}
      {%- assign related_handle = tag | remove: 'goal:' | handleize -%}
      {%- break -%}
    {%- endif -%}
  {%- endfor -%}
  {%- if related_handle == blank -%}
    {%- assign related_handle = product.type | handleize -%}
  {%- endif -%}
  {%- assign related_collection = collections[related_handle] -%}
  {%- if related_collection != blank and related_collection.products.size > 0 -%}
    {%- assign related = related_collection.products -%}
  {%- else -%}
    {%- assign related = collections.all.products -%}
  {%- endif -%}
  {%- if related.size > 1 -%}
    <div style="margin-top:96px">
      <h3 style="margin-bottom:24px">Pairs well with</h3>
      <div class="products-row">
        {%- for p in related limit: 4 -%}
          {%- if p.id != product.id -%}
            {% render 'product-card', product: p %}
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  {%- endif -%}
</div>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Product",
  "name": {{ product.title | json }},
  "description": {{ product.description | strip_html | json }},
  "image": {{ product.featured_image | image_url: width: 1200 | prepend: 'https:' | json }},
  "brand": { "@type": "Brand", "name": "Vivid Health" },
  "offers": {
    "@type": "Offer",
    "url": {{ shop.url | append: product.url | json }},
    "priceCurrency": "ZAR",
    "price": {{ current_variant.price | money_without_currency | remove: ',' | json }},
    "availability": {{ current_variant.available | json | replace: 'true', '"https://schema.org/InStock"' | replace: 'false', '"https://schema.org/OutOfStock"' }}
  }
}
</script>

{% schema %}
{
  "name": "Product main",
  "settings": []
}
{% endschema %}
