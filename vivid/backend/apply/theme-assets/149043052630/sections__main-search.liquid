{%- comment -%}
  Branded search — replaces the default Shopify search rendering.
  Products render through the standard product-card; articles and pages
  get compact rows. Query preserved, 24 per page.
{%- endcomment -%}

<section class="page-head" style="padding:56px 0 8px">
  <div class="wrap">
    <p class="kicker" style="font-size:12px;letter-spacing:.16em;text-transform:uppercase;color:var(--moss);font-weight:600;margin-bottom:10px">Search</p>
    <h1 style="margin-bottom:18px">{% if search.performed %}&ldquo;{{ search.terms | escape }}&rdquo;{% else %}Search the range{% endif %}</h1>
    <form action="{{ routes.search_url }}" method="get" role="search" style="display:flex;gap:10px;max-width:560px;margin-bottom:8px">
      <input type="search" name="q" value="{{ search.terms | escape }}" placeholder="Try &ldquo;magnesium&rdquo;, &ldquo;sleep&rdquo;, &ldquo;joints&rdquo;&hellip;"
        style="flex:1;padding:14px 18px;border:1.5px solid var(--ink-soft,#6b7a70);border-radius:12px;background:var(--paper,#FBF7EE);font:inherit;font-size:16px" aria-label="Search">
      <button type="submit" class="btn" style="padding:14px 26px">Search</button>
    </form>
    {%- if search.performed -%}
      <p style="color:var(--ink-soft);font-size:14px;margin:6px 0 0">{{ search.results_count }} result{% if search.results_count != 1 %}s{% endif %}</p>
    {%- endif -%}
  </div>
</section>

{%- if search.performed -%}
  {%- paginate search.results by 24 -%}
    {%- assign product_results = search.results | where: 'object_type', 'product' -%}
    {%- assign other_results_count = search.results_count | minus: product_results.size -%}
    <section class="wrap" style="padding:24px 0 40px">
      {%- if product_results.size > 0 -%}
        <div class="products-row products-row--shop products-row--3col">
          {%- for product in product_results -%}
            {% render 'product-card', product: product %}
          {%- endfor -%}
        </div>
      {%- endif -%}

      {%- assign shown_other = 0 -%}
      {%- for item in search.results -%}
        {%- unless item.object_type == 'product' -%}
          {%- if shown_other == 0 -%}
            <h2 style="font-size:22px;margin:44px 0 14px">Guides &amp; pages</h2>
            <div style="display:grid;gap:10px;max-width:720px">
          {%- endif -%}
          {%- assign shown_other = shown_other | plus: 1 -%}
          <a href="{{ item.url }}" style="display:block;padding:16px 18px;border:1px solid var(--cream,#EEE5D2);border-radius:12px;background:var(--bone,#F4EEE2);text-decoration:none;color:inherit">
            <strong style="display:block;margin-bottom:4px">{{ item.title }}</strong>
            <span style="font-size:13.5px;color:var(--ink-soft)">{{ item.content | strip_html | split: '.' | first }}.</span>
          </a>
        {%- endunless -%}
      {%- endfor -%}
      {%- if shown_other > 0 -%}</div>{%- endif -%}

      {%- if search.results_count == 0 -%}
        <div style="text-align:center;padding:48px 0 24px">
          <p style="font-size:17px;margin-bottom:16px">Nothing matched &mdash; but a consultant will know.</p>
          <a class="btn" href="https://wa.me/27713744910?text=Hi%2C%20I%20searched%20for%20{{ search.terms | url_encode }}%20on%20the%20Vivid%20site" target="_blank" rel="noopener">WhatsApp a consultant</a>
          <p style="margin-top:14px"><a href="/collections/all-formulations">Or browse all formulations &rarr;</a></p>
        </div>
      {%- endif -%}

      {%- if paginate.pages > 1 -%}
        <nav style="display:flex;gap:8px;justify-content:center;margin-top:36px" aria-label="Pagination">
          {%- if paginate.previous -%}<a class="btn btn--ghost" href="{{ paginate.previous.url }}">&larr; Previous</a>{%- endif -%}
          {%- if paginate.next -%}<a class="btn btn--ghost" href="{{ paginate.next.url }}">Next &rarr;</a>{%- endif -%}
        </nav>
      {%- endif -%}
    </section>
  {%- endpaginate -%}
{%- endif -%}

{% schema %}
{ "name": "Search results", "settings": [] }
{% endschema %}
