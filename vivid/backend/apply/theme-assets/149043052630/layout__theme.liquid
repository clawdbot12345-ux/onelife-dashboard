<!doctype html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover">
  <meta name="theme-color" content="{{ settings.color_forest | default: '#1F3D2E' }}">
  <link rel="canonical" href="{{ canonical_url }}">

  {%- if settings.favicon != blank -%}
    <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32 }}">
  {%- endif -%}

  <title>
    {%- if template.name == 'product' -%}
      {{ product.title }} — {{ shop.name }}
    {%- elsif template.name == 'collection' -%}
      {{ collection.title }} — {{ shop.name }}
    {%- else -%}
      {{ page_title }}
    {%- endif -%}
  </title>

  {%- if page_description -%}
    <meta name="description" content="{{ page_description | escape }}">
  {%- endif -%}

  {%- comment -%} Open Graph + Twitter card. Picks the best available image
    per template: product featured, article hero, collection image, then
    a Vivid fallback. {%- endcomment -%}
  {%- assign og_image = blank -%}
  {%- if template.name == 'product' and product.featured_image -%}
    {%- assign og_image = product.featured_image | image_url: width: 1200 -%}
    {%- assign og_type = 'product' -%}
  {%- elsif template.name == 'article' and article.image -%}
    {%- assign og_image = article.image | image_url: width: 1200 -%}
    {%- assign og_type = 'article' -%}
  {%- elsif template.name == 'collection' and collection.image -%}
    {%- assign og_image = collection.image | image_url: width: 1200 -%}
    {%- assign og_type = 'website' -%}
  {%- else -%}
    {%- assign og_image = 'banner-hero-evening.jpg' | asset_url -%}
    {%- assign og_type = 'website' -%}
  {%- endif -%}

  <meta property="og:site_name" content="{{ shop.name }}">
  <meta property="og:title" content="{{ page_title | escape }}">
  {%- if page_description -%}<meta property="og:description" content="{{ page_description | escape }}">{%- endif -%}
  <meta property="og:type" content="{{ og_type }}">
  <meta property="og:url" content="{{ canonical_url }}">
  <meta property="og:image" content="{{ og_image }}">
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="630">
  <meta property="og:locale" content="{{ request.locale.iso_code | replace: '-', '_' | default: 'en_ZA' }}">

  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:site" content="@vividhealthsa">
  <meta name="twitter:title" content="{{ page_title | escape }}">
  {%- if page_description -%}<meta name="twitter:description" content="{{ page_description | escape }}">{%- endif -%}
  <meta name="twitter:image" content="{{ og_image }}">

  {%- comment -%} Product-specific OG markup {%- endcomment -%}
  {%- if template.name == 'product' and product -%}
    <meta property="og:price:amount" content="{{ product.price | money_without_currency | strip_html }}">
    <meta property="og:price:currency" content="{{ shop.currency }}">
    <meta property="product:price:amount" content="{{ product.price | money_without_currency | strip_html }}">
    <meta property="product:price:currency" content="{{ shop.currency }}">
    <meta property="product:availability" content="{% if product.available %}in stock{% else %}out of stock{% endif %}">
    <meta property="product:brand" content="{{ product.vendor }}">
  {%- endif -%}

  {%- comment -%} Article-specific OG markup {%- endcomment -%}
  {%- if template.name == 'article' and article -%}
    <meta property="article:published_time" content="{{ article.published_at | date: '%Y-%m-%dT%H:%M:%S%z' }}">
    <meta property="article:modified_time" content="{{ article.updated_at | date: '%Y-%m-%dT%H:%M:%S%z' }}">
    <meta property="article:author" content="{{ article.author }}">
    {%- for tag in article.tags -%}
      <meta property="article:tag" content="{{ tag | escape }}">
    {%- endfor -%}
  {%- endif -%}

  {%- comment -%} Organization JSON-LD — emitted globally so every page tells
    Google who Vivid Health is. {%- endcomment -%}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": {{ shop.name | json }},
    "url": "{{ shop.url }}",
    "logo": "{{ 'banner-about.jpg' | asset_url }}",
    "description": "Plant-first supplements made in Centurion, South Africa. Every milligram on every label. Vegetable capsules, third-party lab tested.",
    "foundingDate": "1996",
    "sameAs": [
      "https://www.instagram.com/vividhealthsa",
      "https://www.tiktok.com/@vividhealthsa",
      "https://www.facebook.com/profile.php?id=61550996819121"
    ],
    "contactPoint": {
      "@type": "ContactPoint",
      "telephone": "+27 12 654 3740",
      "email": "orders@vividhealthsa.co.za",
      "contactType": "customer service",
      "areaServed": "ZA",
      "availableLanguage": ["en"]
    },
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "Cnr Galway & Kilkenny Road, Hennopspark",
      "addressLocality": "Centurion",
      "addressRegion": "Gauteng",
      "postalCode": "0157",
      "addressCountry": "ZA"
    }
  }
  </script>

  {%- comment -%} WebSite JSON-LD with a sitelinks search box {%- endcomment -%}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": {{ shop.name | json }},
    "url": "{{ shop.url }}",
    "potentialAction": {
      "@type": "SearchAction",
      "target": "{{ shop.url }}/search?q={search_term_string}",
      "query-input": "required name=search_term_string"
    }
  }
  </script>

  <link rel="preconnect" href="https://cdn.shopify.com" crossorigin>

  {% style %}
    {{ settings.font_display | font_face: font_display: 'swap' }}
    {{ settings.font_body | font_face: font_display: 'swap' }}

    :root {
      --font-display: {{ settings.font_display.family }}, {{ settings.font_display.fallback_families }};
      --font-sans: {{ settings.font_body.family }}, {{ settings.font_body.fallback_families }};
      {%- if settings.color_paper != blank %}--paper: {{ settings.color_paper }};{% endif -%}
      {%- if settings.color_bone != blank %}--bone: {{ settings.color_bone }};{% endif -%}
      {%- if settings.color_cream != blank %}--cream: {{ settings.color_cream }};{% endif -%}
      {%- if settings.color_ink != blank %}--ink: {{ settings.color_ink }};{% endif -%}
      {%- if settings.color_forest != blank %}--forest: {{ settings.color_forest }};{% endif -%}
      {%- if settings.color_forest_deep != blank %}--forest-deep: {{ settings.color_forest_deep }};{% endif -%}
      {%- if settings.color_moss != blank %}--moss: {{ settings.color_moss }};{% endif -%}
      {%- if settings.color_sage != blank %}--sage: {{ settings.color_sage }};{% endif -%}
      {%- if settings.color_clay != blank %}--clay: {{ settings.color_clay }};{% endif -%}
      {%- if settings.container_max %}--container: {{ settings.container_max }}px;{% endif -%}
    }
  {% endstyle %}

  {{ 'base.css' | asset_url | stylesheet_tag }}

  {% render 'breadcrumb-jsonld' %}

  {{ content_for_header }}
</head>
<body class="template-{{ template.name }}"
  {%- if template.name == 'index' %} data-sticky-cta="home"{% endif -%}
>
  <a class="skip" href="#main">Skip to content</a>

  {% section 'announcement-bar' %}
  {% section 'header' %}

  <main id="main" role="main">
    {{ content_for_layout }}
  </main>

  {% section 'footer' %}

  {% render 'cart-drawer' %}
  {% render 'mobile-nav' %}
  {% render 'floating-contact' %}

  <script src="{{ 'theme.js' | asset_url }}" defer></script>
</body>
</html>
