{
  "sections": {
    "main": {
      "type": "main-blog",
      "settings": {
        "layout": "collage",
        "show_image": true,
        "image_height": "medium",
        "show_date": true,
        "show_author": false,
        "padding_top": 36,
        "padding_bottom": 36
      }
    },
    "email-capture": {
      "type": "custom-liquid",
      "settings": {
        "custom_liquid": "{% render 'blog-email-capture' %}",
        "padding_top": 0,
        "padding_bottom": 0
      }
    }
  },
  "order": [
    "main",
    "email-capture"
  ]
}
