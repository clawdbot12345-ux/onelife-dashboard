{%- if template contains 'article' -%}
<div style="background:linear-gradient(135deg,#2d6a4f,#40916c); border-radius:12px; padding:28px 24px; margin:30px 0; text-align:center; color:#fff;">
  <p style="font-size:20px; font-weight:700; margin:0 0 8px; color:#fff;">Get 10% off your first order</p>
  <p style="font-size:14px; margin:0 0 16px; color:#d8f3dc;">Join thousands of South Africans getting expert health tips + exclusive deals every week.</p>
  <form action="https://onelife.co.za/#ol-community" method="get" style="display:flex; gap:8px; max-width:450px; margin:0 auto; flex-wrap:wrap; justify-content:center;">
    <input type="email" placeholder="Your email address" style="flex:1; min-width:200px; padding:12px 16px; border:none; border-radius:6px; font-size:14px;" required>
    <button type="submit" style="background:#fff; color:#1b4332; padding:12px 24px; border:none; border-radius:6px; font-weight:700; font-size:14px; cursor:pointer;">GET 10% OFF</button>
  </form>
  <p style="font-size:11px; margin:8px 0 0; color:#b7e4c7;">No spam. Unsubscribe anytime.</p>
</div>
{%- endif -%}
