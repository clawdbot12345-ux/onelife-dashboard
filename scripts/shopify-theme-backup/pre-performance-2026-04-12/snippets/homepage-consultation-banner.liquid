{%- if template == 'index' -%}
<style>
.ol-consult-banner {
  max-width: 1200px;
  margin: 40px auto;
  padding: 0 20px;
}
.ol-consult-inner {
  background: linear-gradient(135deg, #1b4332 0%, #2d6a4f 50%, #40916c 100%);
  border-radius: 16px;
  padding: 40px 30px;
  display: flex;
  align-items: center;
  gap: 30px;
  color: #fff;
  overflow: hidden;
  position: relative;
}
.ol-consult-text {
  flex: 1;
  z-index: 1;
}
.ol-consult-badge {
  display: inline-block;
  background: rgba(255,255,255,0.2);
  padding: 4px 14px;
  border-radius: 20px;
  font-size: 12px;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 1px;
  margin-bottom: 12px;
}
.ol-consult-title {
  font-size: 26px;
  font-weight: 700;
  line-height: 1.3;
  margin-bottom: 12px;
  color: #fff;
}
.ol-consult-desc {
  font-size: 15px;
  line-height: 1.6;
  opacity: 1; line-height: 1.6;
  margin-bottom: 20px;
}
.ol-consult-cta {
  display: inline-block;
  background: #fff;
  color: #1b4332;
  padding: 14px 28px;
  border-radius: 8px;
  font-size: 15px;
  font-weight: 700;
  text-decoration: none;
  transition: transform 0.2s, box-shadow 0.2s;
}
.ol-consult-cta:hover {
  transform: translateY(-2px);
  box-shadow: 0 6px 20px rgba(0,0,0,0.3);
  color: #1b4332;
}
.ol-consult-emoji {
  font-size: 80px;
  z-index: 1;
}
@media (max-width: 768px) {
  .ol-consult-inner { flex-direction: column; text-align: center; padding: 30px 20px; }
  .ol-consult-title { font-size: 22px; }
  .ol-consult-emoji { font-size: 56px; }
}
</style>
<div class="ol-consult-banner">
  <div class="ol-consult-inner">
    <div class="ol-consult-text">
      <span class="ol-consult-badge">Free Service</span>
      <h2 class="ol-consult-title">Book a Free 15-Minute Health Consultation</h2>
      <p class="ol-consult-desc">
        Chat with our qualified health professionals with <strong>15+ years of experience</strong>.
        Get personalised supplement recommendations for your specific health goals — no obligation, no pressure.
      </p>
      <a href="/pages/book-consultation" class="ol-consult-cta">Book via WhatsApp &rarr;</a>
    </div>
    <div class="ol-consult-emoji">&#129657;</div>
  </div>
</div>
{%- endif -%}
