<script>
  (function() {
    var ids = ['chatbase-bubble-button','chatbase-bubble-window','chatbase-message-bubbles'];
    function moveChatbase() {
      ids.forEach(function(id) {
        var el = document.getElementById(id);
        if (el) {
          el.style.setProperty('right','auto','important');
          el.style.setProperty('left','20px','important');
        }
      });
    }
    var obs = new MutationObserver(moveChatbase);
    obs.observe(document.documentElement, { childList: true, subtree: true, attributes: true, attributeFilter: ['style'] });
    window.addEventListener('load', moveChatbase);
  })();
</script>
  

<script>
  /* Smile.io launcher — hide on mobile (conflicts with chat widget) */
  (function() {
    function fixSmile() {
      /* Try both known Smile.io element IDs */
      var el = document.getElementById('smile-ui') || document.getElementById('smile-ui-container') || document.querySelector('[id^="smile-"]');
      if (!el) return;
      if (window.innerWidth <= 768) {
        el.style.setProperty('display', 'none', 'important');
      } else {
        el.style.setProperty('left', '12px', 'important');
        el.style.setProperty('right', 'auto', 'important');
        el.style.setProperty('bottom', '24px', 'important');
        el.style.removeProperty('display');
      }
    }
    fixSmile();
    var obs = new MutationObserver(fixSmile);
    obs.observe(document.body, { childList: true, subtree: true, attributes: true });
    window.addEventListener('resize', fixSmile);
  })();
</script>


