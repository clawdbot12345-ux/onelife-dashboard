  <style>
    /* Smile.io Rewards — desktop: bottom-left; mobile: hidden (blocks chat widget) */
    #smile-ui,
    #smile-ui-container,
    [id^="smile-"] iframe,
    .smile-launcher {
      left: 12px !important;
      right: auto !important;
      bottom: 24px !important;
    }
    @media (max-width: 768px) {
      #smile-ui,
      #smile-ui-container,
      [id^="smile-"] iframe,
      .smile-launcher {
        display: none !important;
      }
    }
    /* Cart free delivery threshold UI — hidden during nationwide free-delivery campaign */
    .ship_nt_wrap,
    .threshold_bar,
    .threshold_bar .animate,
    .threshold_bar span.animate,
    .shipping_nt,
    .thresholdError,
    [class*="threshold_bar"],
    [class*="ship_nt_wrap"] {
      display: none !important;
    }
    /* Header signup banner hidden during free-delivery campaign */
    .header-banner,
    #header-banner-wrapper,
    .header-banner-enabled .header-banner {
      display: none !important;
    }
    /* Hide duplicate built-in grey top bar while custom signup bar is active */
    .topbar-wrapp {
      display: none !important;
    }
    /* Top Supplements mobile tabs: 2 columns, multiple rows, cleaner touch layout */
    @media (max-width: 767px) {
      #shopify-section-1511431962876 .gl_tta-tabs-container {
        margin-bottom: 18px !important;
      }
      #shopify-section-1511431962876 .gl_tta-tabs-list {
        display: grid !important;
        grid-template-columns: repeat(2, minmax(0, 1fr)) !important;
        gap: 10px 12px !important;
        margin: 0 !important;
        padding: 0 !important;
      }
      #shopify-section-1511431962876 .gl_tta-tab {
        width: auto !important;
        display: block !important;
        float: none !important;
        margin: 0 !important;
        padding: 0 !important;
        border: none !important;
      }
      #shopify-section-1511431962876 .gl_tta-tab:after,
      #shopify-section-1511431962876 .gl_tta-tab:before,
      #shopify-section-1511431962876 .gl_tta-tab > a:after,
      #shopify-section-1511431962876 .gl_tta-tab > a:before {
        display: none !important;
        content: none !important;
      }
      #shopify-section-1511431962876 .gl_tta-tab > a {
        display: flex !important;
        align-items: center !important;
        justify-content: center !important;
        min-height: 46px !important;
        padding: 10px 12px !important;
        text-align: center !important;
        line-height: 1.25 !important;
        font-size: 14px !important;
        font-weight: 600 !important;
        border: 1px solid rgba(0,0,0,0.10) !important;
        border-radius: 10px !important;
        background: #f7f7f2 !important;
      }
      #shopify-section-1511431962876 .gl_tta-tab.gl_active > a,
      #shopify-section-1511431962876 .gl_tta-tab > a:hover {
        background: #eef5ec !important;
        border-color: #a7c6a6 !important;
        color: #6b8f66 !important;
      }
    }

    /* Header signup banner: auto-height, single line, no empty space */
    .header-banner {
      height: auto !important;
      min-height: unset !important;
      padding: 6px 36px !important;
      white-space: nowrap !important;
      overflow: hidden !important;
      text-overflow: ellipsis !important;
      margin-bottom: 0 !important;
    }
    /* Remove gap between signup bar and delivery bar */
    .header-banner + *,
    .header-banner ~ .top-bar,
    .header-banner ~ .gl_top_bar,
    #header-banner-wrapper + *,
    .website-wrapper {
      margin-top: 0 !important;
    }
    .header-banner-enabled .top-bar,
    .header-banner-enabled .gl_top_bar,
    .header-banner-enabled #top-bar {
      margin-top: 0 !important;
      top: 0 !important;
    }
  </style>

