{%- comment -%}
  Social proof / stats bar for homepage. Shows key trust metrics.
  Added 2026-04-12.
{%- endcomment -%}
{%- if template == 'index' -%}
<style>
.ol-proof-bar {
  background: #2c2c2c;
  border-bottom: 1px solid #e9ecef;
  padding: 18px 20px;
}
.ol-proof-inner {
  max-width: 1200px;
  margin: 0 auto;
  display: flex;
  justify-content: center;
  flex-wrap: wrap;
  gap: 12px 40px;
}
.ol-proof-stat {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 14px;
  color: #fff;
}
.ol-proof-num {
  font-weight: 700;
  font-size: 18px;
  color: #7ec8a0;
}
.ol-proof-label {
  font-weight: 400;
  color: #d4d4d4;
}
@media (max-width: 600px) {
  .ol-proof-inner { gap: 8px 24px; }
  .ol-proof-num { font-size: 16px; }
  .ol-proof-stat { font-size: 13px; }
}
</style>
<div class="ol-proof-bar">
  <div class="ol-proof-inner">
    <div class="ol-proof-stat">
      <span class="ol-proof-num">10,000+</span>
      <span class="ol-proof-label">Health Products</span>
    </div>
    <div class="ol-proof-stat">
      <span class="ol-proof-num">200+</span>
      <span class="ol-proof-label">Trusted Brands</span>
    </div>
    <div class="ol-proof-stat">
      <span class="ol-proof-num">3</span>
      <span class="ol-proof-label">Stores in Gauteng</span>
    </div>
    <div class="ol-proof-stat">
      <span class="ol-proof-num">25+</span>
      <span class="ol-proof-label">Years Serving SA</span>
    </div>
  </div>
</div>
{%- endif -%}
