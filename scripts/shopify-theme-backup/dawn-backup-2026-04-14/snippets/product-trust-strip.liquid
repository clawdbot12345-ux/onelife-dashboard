{%- comment -%}
  Product page trust strip — shows key buying confidence signals
  directly below the product info. Added 2026-04-12.
{%- endcomment -%}
<style>
.ol-trust-strip {
  display: flex;
  flex-wrap: wrap;
  gap: 8px 20px;
  padding: 16px 0;
  margin: 16px 0;
  border-top: 1px solid #e9ecef;
  border-bottom: 1px solid #e9ecef;
}
.ol-trust-item {
  display: flex;
  align-items: center;
  gap: 6px;
  font-size: 13px;
  color: #495057;
  white-space: nowrap;
}
.ol-trust-item svg {
  width: 18px;
  height: 18px;
  flex-shrink: 0;
}
.ol-trust-icon { color: #2d6a4f; }
@media (max-width: 600px) {
  .ol-trust-strip { gap: 6px 14px; }
  .ol-trust-item { font-size: 12px; }
}
</style>
<div class="ol-trust-strip">
  <div class="ol-trust-item">
    <svg class="ol-trust-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
    <span>Free delivery over R400</span>
  </div>
  <div class="ol-trust-item">
    <svg class="ol-trust-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
    <span>Collect in-store</span>
  </div>
  <div class="ol-trust-item">
    <svg class="ol-trust-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 4v6h6"/><path d="M3.51 15a9 9 0 100-6.36L1 10"/></svg>
    <span>Easy returns</span>
  </div>
  <div class="ol-trust-item">
    <svg class="ol-trust-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg>
    <span>Secure checkout</span>
  </div>
</div>
