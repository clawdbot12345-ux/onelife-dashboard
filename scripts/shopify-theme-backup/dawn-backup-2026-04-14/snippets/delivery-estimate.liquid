{%- if template contains 'product' -%}
<div style="margin:12px 0;padding:10px 14px;background:#f0fdf4;border-radius:6px;border:1px solid #d1fae5;">
  {%- if product.available -%}
    <p style="margin:0;font-size:13px;color:#1b4332;">
      🚚 <strong>Estimated delivery:</strong> 3–7 business days
    </p>
    <p style="margin:4px 0 0;font-size:11px;color:#666;">
      Order before 12pm for same-day dispatch
    </p>
  {%- else -%}
    <p style="margin:0;font-size:13px;color:#dc2626;">
      ⚠️ Currently out of stock
    </p>
  {%- endif -%}
</div>
{%- endif -%}