<nav class="ol-breadcrumbs" aria-label="Breadcrumb" style="max-width:var(--page-width);margin:0 auto;padding:0 1.5rem;">
  <div style="background:#f7f5f0;border-radius:6px;padding:10px 16px;margin-top:12px;">
    <ol style="list-style:none;display:flex;flex-wrap:wrap;align-items:center;gap:6px;margin:0;padding:0;font-size:13px;">
      <li><a href="/" style="color:#2d6a4f;text-decoration:none;font-weight:600;">Home</a></li>
      {%- if collection -%}
        <li style="color:#bbb;">&#8250;</li>
        <li style="color:#1a1a1a;font-weight:600;">{{ collection.title }}</li>
      {%- endif -%}
      {%- if product -%}
        {%- if product.collections.size > 0 -%}
          <li style="color:#bbb;">&#8250;</li>
          <li><a href="{{ product.collections.first.url }}" style="color:#2d6a4f;text-decoration:none;font-weight:600;">{{ product.collections.first.title }}</a></li>
        {%- endif -%}
        <li style="color:#bbb;">&#8250;</li>
        <li style="color:#1a1a1a;font-weight:500;">{{ product.title | truncate: 40 }}</li>
      {%- endif -%}
    </ol>
  </div>
</nav>