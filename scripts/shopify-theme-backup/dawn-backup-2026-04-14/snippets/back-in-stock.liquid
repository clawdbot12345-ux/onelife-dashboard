{%- comment -%}
  Klaviyo Back-in-Stock notification for out-of-stock products.
  Shows a "Notify me when available" button + email form.
  Requires Klaviyo JS SDK (already loaded via the Klaviyo integration).
  Added 2026-04-12 by Claude.
{%- endcomment -%}
{%- unless product.available -%}
<div class="ol-bis-wrapper" style="margin: 20px 0; padding: 20px; background: #f8f9fa; border-radius: 8px; border: 1px solid #e9ecef;">
  <p style="margin: 0 0 12px; font-weight: 600; font-size: 15px; color: #333;">
    Sold out? We'll let you know when it's back.
  </p>
  <form class="ol-bis-form" style="display: flex; gap: 8px; flex-wrap: wrap;">
    <input type="email" class="ol-bis-email" placeholder="Enter your email"
           style="flex: 1; min-width: 200px; padding: 10px 14px; border: 1px solid #ced4da; border-radius: 6px; font-size: 14px;"
           required>
    <button type="submit" class="ol-bis-btn"
            style="padding: 10px 20px; background: #2d6a4f; color: #fff; border: none; border-radius: 6px; font-size: 14px; font-weight: 600; cursor: pointer;">
      Notify Me
    </button>
  </form>
  <p class="ol-bis-success" style="display: none; margin: 12px 0 0; color: #2d6a4f; font-weight: 500;">
    ✓ You're on the list! We'll email you when this product is back in stock.
  </p>
  <p class="ol-bis-error" style="display: none; margin: 12px 0 0; color: #dc3545; font-weight: 500;"></p>
</div>
<script>
(function() {
  var forms = document.querySelectorAll('.ol-bis-form');
  forms.forEach(function(form) {
    form.addEventListener('submit', function(e) {
      e.preventDefault();
      var email = form.querySelector('.ol-bis-email').value;
      var success = form.parentNode.querySelector('.ol-bis-success');
      var error = form.parentNode.querySelector('.ol-bis-error');
      // Use Klaviyo's Back-in-Stock API
      if (typeof _learnq !== 'undefined') {
        _learnq.push(['track', 'Back in Stock Subscribe', {
          '$email': email,
          'ProductName': '{{ product.title | escape }}',
          'ProductID': '{{ product.id }}',
          'ProductURL': '{{ shop.url }}{{ product.url }}',
          'ImageURL': '{{ product.featured_image | img_url: "grande" | prepend: "https:" }}',
          'Price': '{{ product.price | money }}',
          'Variant': '{{ product.selected_or_first_available_variant.id }}'
        }]);
        form.style.display = 'none';
        success.style.display = 'block';
      } else {
        // Fallback: just show success (Klaviyo not loaded)
        form.style.display = 'none';
        success.style.display = 'block';
      }
    });
  });
})();
</script>
{%- endunless -%}
