<div id="ol-community" style="background:linear-gradient(135deg,#0a6b5c 0%,#108474 60%,#1aa88f 100%);padding:60px 20px;text-align:center;">
  <div style="max-width:680px;margin:0 auto;">
    <p style="color:#a8e6dc;font-size:13px;letter-spacing:2px;text-transform:uppercase;margin:0 0 12px;font-weight:600;">One Life Health Community</p>
    <h2 style="color:#ffffff;font-size:clamp(24px,4vw,36px);font-weight:700;margin:0 0 16px;line-height:1.2;">
      More than a newsletter.<br>Your health advantage.
    </h2>
    <p style="color:#d4f5ef;font-size:16px;line-height:1.6;margin:0 0 32px;max-width:520px;margin-left:auto;margin-right:auto;">
      Join thousands of South Africans who get first access to deals, exclusive member discounts, new arrivals, expert supplement advice and our weekly wellness blog — straight to their inbox.
    </p>
    <!-- Value props -->
    <div style="display:flex;flex-wrap:wrap;justify-content:center;gap:12px 24px;margin-bottom:36px;">
      <span style="color:#a8e6dc;font-size:14px;">✓ <strong style="color:#fff;">10% off</strong> your first order</span>
      <span style="color:#a8e6dc;font-size:14px;">✓ <strong style="color:#fff;">Member-only</strong> specials &amp; sales</span>
      <span style="color:#a8e6dc;font-size:14px;">✓ <strong style="color:#fff;">New arrivals</strong> before anyone else</span>
      <span style="color:#a8e6dc;font-size:14px;">✓ <strong style="color:#fff;">Expert tips</strong> &amp; wellness blogs</span>
      <span style="color:#a8e6dc;font-size:14px;">✓ <strong style="color:#fff;">No spam.</strong> Unsubscribe anytime.</span>
    </div>
    <!-- Signup form -->
    <form action="https://manage.kmail-lists.com/subscriptions/subscribe" method="POST"
          target="_blank"
          style="display:flex;gap:0;justify-content:center;max-width:480px;margin:0 auto 16px;box-shadow:0 4px 24px rgba(0,0,0,0.2);border-radius:6px;overflow:hidden;height:52px;">
      <input type="hidden" name="g" value="Xrk5jD">
      <input type="hidden" name="$fields" value="$first_name,$email">
      <input type="text" name="first_name" placeholder="First name" required
             style="height:52px;padding:0 14px;border:none;border-right:1px solid #e0e0e0;font-size:15px;outline:none;color:#333;width:130px;flex-shrink:0;box-sizing:border-box;">
      <input type="email" name="email" placeholder="Email address" required
             style="flex:1;height:52px;padding:0 14px;border:none;font-size:15px;outline:none;color:#333;min-width:0;box-sizing:border-box;">
      <button type="submit"
              style="height:52px;padding:0 22px;background:#f5a623;color:#fff;border:none;font-size:14px;font-weight:700;cursor:pointer;white-space:nowrap;letter-spacing:0.4px;box-sizing:border-box;flex-shrink:0;">
        GET 10% OFF →
      </button>
    </form>
    <p style="color:#7dd4c8;font-size:12px;margin:0;">
      By subscribing you agree to receive marketing emails from One Life Health. Unsubscribe anytime.
    </p>
  </div>
</div>

{% schema %}
{
  "name": "Community Signup",
  "settings": []
}
{% endschema %}