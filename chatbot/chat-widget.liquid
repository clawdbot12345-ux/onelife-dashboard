{%- comment -%}
  Onelife Health AI Chat Widget
  Powered by Claude — knows the full product catalogue
  Replace WORKER_URL with your deployed Cloudflare Worker URL
{%- endcomment -%}

<style>
.ol-chat-btn {
  position: fixed;
  bottom: 20px;
  right: 80px;
  z-index: 997;
  width: 56px;
  height: 56px;
  border-radius: 50%;
  background: linear-gradient(135deg, #2d6a4f, #1b4332);
  border: none;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4px 16px rgba(0,0,0,0.2);
  transition: transform 0.2s, box-shadow 0.2s;
}
.ol-chat-btn:hover {
  transform: scale(1.08);
  box-shadow: 0 6px 24px rgba(0,0,0,0.25);
}
.ol-chat-btn svg { width: 28px; height: 28px; fill: #fff; }

@media (max-width: 749px) {
  .ol-chat-btn {
    bottom: 62px;
    right: 72px;
    width: 48px;
    height: 48px;
  }
  .ol-chat-btn svg { width: 24px; height: 24px; }
}

/* Chat panel */
.ol-chat-panel {
  display: none;
  position: fixed;
  bottom: 90px;
  right: 20px;
  width: 380px;
  max-height: 520px;
  z-index: 9999;
  border-radius: 16px;
  overflow: hidden;
  box-shadow: 0 12px 48px rgba(0,0,0,0.15);
  flex-direction: column;
  background: #fff;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
}
.ol-chat-panel.open { display: flex; }

@media (max-width: 749px) {
  .ol-chat-panel {
    bottom: 0;
    right: 0;
    left: 0;
    width: 100%;
    max-height: 85vh;
    border-radius: 16px 16px 0 0;
  }
}

/* Header */
.ol-chat-header {
  background: linear-gradient(135deg, #2d6a4f, #1b4332);
  color: #fff;
  padding: 16px;
  display: flex;
  align-items: center;
  gap: 12px;
}
.ol-chat-avatar {
  width: 40px;
  height: 40px;
  border-radius: 50%;
  background: rgba(255,255,255,0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20px;
  flex-shrink: 0;
}
.ol-chat-header-text h3 {
  margin: 0;
  font-size: 15px;
  font-weight: 700;
  color: #fff !important;
}
.ol-chat-header-text p {
  margin: 2px 0 0;
  font-size: 11px;
  color: rgba(255,255,255,0.7);
}
.ol-chat-close {
  margin-left: auto;
  background: none;
  border: none;
  color: #fff;
  font-size: 20px;
  cursor: pointer;
  padding: 4px;
  opacity: 0.7;
}
.ol-chat-close:hover { opacity: 1; }

/* Messages */
.ol-chat-messages {
  flex: 1;
  overflow-y: auto;
  padding: 16px;
  display: flex;
  flex-direction: column;
  gap: 12px;
  background: #f8f9fa;
  min-height: 200px;
  max-height: 340px;
}

.ol-chat-msg {
  max-width: 85%;
  padding: 10px 14px;
  border-radius: 12px;
  font-size: 13px;
  line-height: 1.5;
  word-wrap: break-word;
}
.ol-chat-msg a {
  color: #2d6a4f;
  text-decoration: underline;
}
.ol-chat-msg-bot {
  background: #fff;
  color: #333;
  align-self: flex-start;
  border: 1px solid #e8e8e8;
  border-bottom-left-radius: 4px;
}
.ol-chat-msg-user {
  background: #2d6a4f;
  color: #fff;
  align-self: flex-end;
  border-bottom-right-radius: 4px;
}
.ol-chat-typing {
  align-self: flex-start;
  background: #fff;
  border: 1px solid #e8e8e8;
  padding: 10px 16px;
  border-radius: 12px;
  font-size: 13px;
  color: #999;
}
.ol-chat-typing span {
  animation: ol-dot 1.4s infinite;
  display: inline-block;
}
.ol-chat-typing span:nth-child(2) { animation-delay: 0.2s; }
.ol-chat-typing span:nth-child(3) { animation-delay: 0.4s; }
@keyframes ol-dot {
  0%, 60%, 100% { opacity: 0.3; }
  30% { opacity: 1; }
}

/* Input */
.ol-chat-input-area {
  padding: 12px;
  border-top: 1px solid #eee;
  display: flex;
  gap: 8px;
  background: #fff;
}
.ol-chat-input {
  flex: 1;
  border: 1.5px solid #ddd;
  border-radius: 8px;
  padding: 10px 12px;
  font-size: 13px;
  outline: none;
  resize: none;
  font-family: inherit;
  max-height: 80px;
}
.ol-chat-input:focus {
  border-color: #2d6a4f;
}
.ol-chat-send {
  background: #2d6a4f;
  border: none;
  border-radius: 8px;
  width: 40px;
  height: 40px;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  flex-shrink: 0;
  transition: background 0.2s;
}
.ol-chat-send:hover { background: #1b4332; }
.ol-chat-send svg { width: 18px; height: 18px; fill: #fff; }
.ol-chat-send:disabled { opacity: 0.5; cursor: not-allowed; }

/* Quick actions */
.ol-chat-quick {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
  padding: 0 16px 12px;
  background: #f8f9fa;
}
.ol-chat-quick button {
  background: #fff;
  border: 1px solid #ddd;
  border-radius: 16px;
  padding: 6px 12px;
  font-size: 11px;
  cursor: pointer;
  color: #555;
  transition: all 0.2s;
}
.ol-chat-quick button:hover {
  border-color: #2d6a4f;
  color: #2d6a4f;
}

/* Notification dot */
.ol-chat-dot {
  position: absolute;
  top: -2px;
  right: -2px;
  width: 14px;
  height: 14px;
  background: #ef4444;
  border-radius: 50%;
  border: 2px solid #fff;
}
</style>

<!-- Chat button -->
<button class="ol-chat-btn" id="ol-chat-toggle" aria-label="Chat with us">
  <svg viewBox="0 0 24 24"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>
  <span class="ol-chat-dot" id="ol-chat-dot"></span>
</button>

<!-- Chat panel -->
<div class="ol-chat-panel" id="ol-chat-panel">
  <div class="ol-chat-header">
    <div class="ol-chat-avatar">🌿</div>
    <div class="ol-chat-header-text">
      <h3>Onelife Health Assistant</h3>
      <p>Powered by AI · Typically replies instantly</p>
    </div>
    <button class="ol-chat-close" id="ol-chat-close">&times;</button>
  </div>

  <div class="ol-chat-messages" id="ol-chat-messages">
    <div class="ol-chat-msg ol-chat-msg-bot">
      Hi there! 👋 I'm the Onelife Health AI Assistant. I can help you find the right supplements, check product availability, or answer any health product questions. How can I help you today?
    </div>
  </div>

  <div class="ol-chat-quick" id="ol-chat-quick">
    <button onclick="olChatQuick('What supplements are good for immunity?')">Immunity</button>
    <button onclick="olChatQuick('Help me with sleep supplements')">Sleep</button>
    <button onclick="olChatQuick('What do you recommend for gut health?')">Gut Health</button>
    <button onclick="olChatQuick('Do you have vegan protein powder?')">Vegan Protein</button>
    <button onclick="olChatQuick('Where are your stores?')">Store Locations</button>
    <button onclick="olChatQuick('Book a free health consultation')">Free Consultation</button>
  </div>

  <div class="ol-chat-input-area">
    <textarea class="ol-chat-input" id="ol-chat-input" placeholder="Ask about supplements, health goals..." rows="1"></textarea>
    <button class="ol-chat-send" id="ol-chat-send">
      <svg viewBox="0 0 24 24"><path d="M2.01 21L23 12 2.01 3 2 10l15 2-15 2z"/></svg>
    </button>
  </div>
</div>

<script>
(function() {
  // REPLACE THIS with your Cloudflare Worker URL after deployment
  var WORKER_URL = '{{ shop.metafields.onelife.chatbot_url | default: "" }}';

  var panel = document.getElementById('ol-chat-panel');
  var messages = document.getElementById('ol-chat-messages');
  var input = document.getElementById('ol-chat-input');
  var sendBtn = document.getElementById('ol-chat-send');
  var dot = document.getElementById('ol-chat-dot');
  var quickActions = document.getElementById('ol-chat-quick');
  var chatHistory = [];

  // Toggle panel
  document.getElementById('ol-chat-toggle').addEventListener('click', function() {
    panel.classList.toggle('open');
    if (panel.classList.contains('open')) {
      dot.style.display = 'none';
      input.focus();
    }
  });

  document.getElementById('ol-chat-close').addEventListener('click', function() {
    panel.classList.remove('open');
  });

  // Send message
  function sendMessage(text) {
    if (!text.trim()) return;

    // Hide quick actions after first message
    if (quickActions) quickActions.style.display = 'none';

    // Add user message
    addMessage(text, 'user');
    chatHistory.push({ role: 'user', content: text });
    input.value = '';
    input.style.height = 'auto';
    sendBtn.disabled = true;

    // Show typing
    var typing = document.createElement('div');
    typing.className = 'ol-chat-typing';
    typing.id = 'ol-typing';
    typing.innerHTML = '<span>.</span><span>.</span><span>.</span>';
    messages.appendChild(typing);
    messages.scrollTop = messages.scrollHeight;

    // Call API
    if (!WORKER_URL) {
      // Fallback if no worker URL configured
      removeTyping();
      addMessage("I'm not fully set up yet. For now, please WhatsApp us at (071) 374 4910 or email orders@onelife.co.za — our team will help you!", 'bot');
      sendBtn.disabled = false;
      return;
    }

    fetch(WORKER_URL, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ messages: chatHistory }),
    })
    .then(function(r) { return r.json(); })
    .then(function(data) {
      removeTyping();
      var reply = data.reply || "Sorry, I couldn't process that. Try again?";
      addMessage(reply, 'bot');
      chatHistory.push({ role: 'assistant', content: reply });
      sendBtn.disabled = false;
    })
    .catch(function() {
      removeTyping();
      addMessage("I'm having trouble connecting. Please try again or WhatsApp us at (071) 374 4910.", 'bot');
      sendBtn.disabled = false;
    });
  }

  function addMessage(text, type) {
    var div = document.createElement('div');
    div.className = 'ol-chat-msg ol-chat-msg-' + type;
    // Convert URLs to links and **bold** to <strong>
    text = text.replace(/\*\*([^*]+)\*\*/g, '<strong>$1</strong>');
    text = text.replace(/(https?:\/\/[^\s<]+)/g, '<a href="$1" target="_blank">View Product</a>');
    text = text.replace(/\n/g, '<br>');
    div.innerHTML = text;
    messages.appendChild(div);
    messages.scrollTop = messages.scrollHeight;
  }

  function removeTyping() {
    var t = document.getElementById('ol-typing');
    if (t) t.remove();
  }

  // Send on button click
  sendBtn.addEventListener('click', function() { sendMessage(input.value); });

  // Send on Enter (Shift+Enter for newline)
  input.addEventListener('keydown', function(e) {
    if (e.key === 'Enter' && !e.shiftKey) {
      e.preventDefault();
      sendMessage(input.value);
    }
  });

  // Auto-resize textarea
  input.addEventListener('input', function() {
    this.style.height = 'auto';
    this.style.height = Math.min(this.scrollHeight, 80) + 'px';
  });

  // Quick action buttons
  window.olChatQuick = function(text) {
    sendMessage(text);
  };
})();
</script>
