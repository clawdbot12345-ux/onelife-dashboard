{%- comment -%}
  One Life Health — PDP Conversion Kit (Growth Build 2026-06)
  Below the buy buttons on every product page.
  + Injects the review summary above the product title (moves with JS).
{%- endcomment -%}

{%- assign free_ship_threshold = 40000 -%}
{%- assign price = product.selected_or_first_available_variant.price -%}
{%- assign gap = free_ship_threshold | minus: price -%}

<template id="ol-pdp-rev-tmpl">{% render 'pdp-review-summary', product: product %}</template>
<script>(function(){var t=document.getElementById('ol-pdp-rev-tmpl');if(!t)return;var c=t.content.cloneNode(true);if(!c.querySelector||!c.querySelector('.ol-pdp-rev'))return;var title=document.querySelector('.product__title');if(!title||title.parentNode.querySelector('#ol-pdp-rev'))return;title.parentNode.insertBefore(c,title);t.remove();})();</script>

<div class="ol-pdp-kit" style="margin:18px 0;display:flex;flex-direction:column;gap:10px;">

  {%- if price < free_ship_threshold -%}
    <div style="background:#f0fdf4;border:1px solid #cfe8d8;border-radius:10px;padding:12px 14px;">
      <div style="display:flex;justify-content:space-between;align-items:baseline;margin-bottom:6px;">
        <span style="font-size:13px;color:#1a1a1a;">Add <strong style="color:#1b4332;">{{ gap | money }}</strong> more for <strong>free delivery</strong></span>
        <span style="font-size:11px;color:#2d6a4f;font-weight:700;white-space:nowrap;">FREE AT R400</span>
      </div>
      <div style="height:4px;background:#dce9de;border-radius:999px;overflow:hidden;">
        {%- assign pct = price | times: 100 | divided_by: free_ship_threshold -%}
        <span style="display:block;height:100%;width:{{ pct }}%;background:linear-gradient(90deg,#2d6a4f,#40916c);border-radius:inherit;"></span>
      </div>
      <p style="margin:8px 0 0;font-size:12px;color:#555;">Most customers pair this with a magnesium, omega-3, or vitamin D — <a href="#ol-pairs-well" style="color:#1b4332;font-weight:600;">see what pairs well ↓</a></p>
    </div>
  {%- else -%}
    <div style="background:#f0fdf4;border:1px solid #cfe8d8;border-radius:10px;padding:12px 14px;">
      <span style="font-size:13px;color:#1b4332;font-weight:600;">✓ This order qualifies for free nationwide delivery</span>
    </div>
  {%- endif -%}

  <div style="background:#fff;border:1px solid #e8e2d6;border-radius:10px;padding:12px 14px;">
    <div style="display:flex;align-items:flex-start;gap:10px;">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#1b4332" stroke-width="2" style="flex-shrink:0;margin-top:2px;"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
      <div>
        <p style="margin:0 0 2px;font-size:13px;font-weight:600;color:#1a1a1a;">Collect free in store — often same day</p>
        <p style="margin:0;font-size:12px;color:#555;line-height:1.5;">Centurion · Glen Village · Edenvale. Order online, skip the courier fee, pick it up when it suits you.</p>
      </div>
    </div>
  </div>

  <div style="background:#fff;border:1px solid #e8e2d6;border-radius:10px;padding:12px 14px;">
    <div style="display:flex;align-items:flex-start;gap:10px;">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#1b4332" stroke-width="2" style="flex-shrink:0;margin-top:2px;"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8z"/></svg>
      <div>
        <p style="margin:0 0 2px;font-size:13px;font-weight:600;color:#1a1a1a;">Not sure it's right for you? Ask before you buy.</p>
        <p style="margin:0;font-size:12px;color:#555;line-height:1.5;">Free WhatsApp consult with our health consultants — 30 years behind the counter. <a href="https://wa.me/27713744910?text=Hi%2C%20I%27m%20looking%20at%20{{ product.title | url_encode }}%20on%20your%20site%20—%20is%20it%20right%20for%20me%3F" style="color:#1b4332;font-weight:600;">Chat now →</a></p>
      </div>
    </div>
  </div>

</div>
