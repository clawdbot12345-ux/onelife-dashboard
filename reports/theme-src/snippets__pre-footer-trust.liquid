<style>
  .ol-pre-foot { background: #1b4332; color: #fff; padding: 22px 16px; }
  .ol-pre-foot__shell { max-width: 1200px; margin: 0 auto; display: grid; grid-template-columns: repeat(4, 1fr); gap: 18px; align-items: center; }
  .ol-pre-foot__item { display: flex; align-items: flex-start; gap: 12px; color: inherit; text-decoration: none; }
  .ol-pre-foot__icon { width: 30px; height: 30px; flex-shrink: 0; color: #b7e4c7; }
  .ol-pre-foot__icon svg { width: 100%; height: 100%; stroke: currentColor; stroke-width: 1.7; fill: none; stroke-linecap: round; stroke-linejoin: round; }
  .ol-pre-foot__copy strong { display: block; font-size: 13.5px; color: #fff; font-weight: 700; line-height: 1.2; margin-bottom: 2px; }
  .ol-pre-foot__copy span { display: block; font-size: 12px; color: #b7e4c7; line-height: 1.4; }
  .ol-pre-foot__copy a { color: #fff; text-decoration: underline; }
  @media (max-width: 900px) { .ol-pre-foot__shell { grid-template-columns: repeat(2, 1fr); gap: 16px; } }
  @media (max-width: 480px) { .ol-pre-foot__shell { grid-template-columns: 1fr; } }
</style>

