{% doc %}
  Renders compact product-page trust proof points below the product summary.

  @example
  {% render 'product-trust-strip' %}
{% enddoc %}

<style>
  .ol-trust-inline {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.8rem;
    margin: 1.8rem 0 1rem;
  }

  .ol-trust-inline__item {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    min-height: 5.6rem;
    padding: 1.1rem 1.2rem;
    background: linear-gradient(135deg, #e1f3eb 0%, #f7fcf9 100%);
    border: 1px solid rgba(31, 111, 84, 0.24);
    border-left: 0.4rem solid #1f6f54;
    border-radius: 1rem;
    box-shadow: 0 0.6rem 1.8rem rgba(27, 67, 50, 0.06);
    color: #123d2e;
    font-size: 1.25rem;
    font-weight: 800;
    line-height: 1.25;
  }

  .ol-trust-inline__item svg {
    width: 1.7rem;
    height: 1.7rem;
    flex: 0 0 1.7rem;
    stroke: #1f6f54;
  }

  @media screen and (max-width: 749px) {
    .ol-trust-inline {
      gap: 0.7rem;
      margin: 1.6rem 0 1rem;
    }

    .ol-trust-inline__item {
      min-height: 5rem;
      padding: 1rem;
      font-size: 1.18rem;
    }

    .ol-trust-inline__item svg {
      width: 1.55rem;
      height: 1.55rem;
      flex-basis: 1.55rem;
    }
  }
</style>

<div class="ol-trust-inline" aria-label="One Life service promises">
  <div class="ol-trust-inline__item">
    <svg viewBox="0 0 24 24" fill="none" stroke-width="2" aria-hidden="true"><path d="M20 21v-2a4 4 0 0 0-3-3.87"/><path d="M4 21v-2a4 4 0 0 1 3-3.87"/><circle cx="12" cy="7" r="4"/></svg>
    <span>Family-owned since 1996</span>
  </div>
  <div class="ol-trust-inline__item">
    <svg viewBox="0 0 24 24" fill="none" stroke-width="2" aria-hidden="true"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
    <span>Consultant-vetted range</span>
  </div>
  <div class="ol-trust-inline__item">
    <svg viewBox="0 0 24 24" fill="none" stroke-width="2" aria-hidden="true"><rect x="1" y="3" width="15" height="13" rx="2"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
    <span>SA stock - no import wait</span>
  </div>
  <div class="ol-trust-inline__item">
    <svg viewBox="0 0 24 24" fill="none" stroke-width="2" aria-hidden="true"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
    <span>Free consult in-store or WhatsApp</span>
  </div>
</div>
