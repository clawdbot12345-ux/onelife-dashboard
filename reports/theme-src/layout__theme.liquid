      if request.page_type == 'index'
        assign ol_meta_description = "South Africa's premium boutique apothecary. 10 000+ supplements, 250+ trusted brands, 30 years of family-owned wellness. Free delivery over R400 nationwide."
      elsif request.page_type == 'collection' and collection and collection.description == blank
        assign ol_meta_description = 'Shop ' | append: collection.title | append: ' at One Life Health. Trusted supplements, health products and nationwide delivery in South Africa.'
