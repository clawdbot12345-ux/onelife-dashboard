    <script>
    (function(){
      var smileObserver;

      function findSmileElements() {
        var selectors = [
          '#smile-ui',
          '#smile-ui-container',
          '#smile-ui-lite-launcher-frame-container',
          '.smile-launcher'
        ];
        var seen = [];

        selectors.forEach(function(selector) {
          document.querySelectorAll(selector).forEach(function(el) {
            if (seen.indexOf(el) === -1) seen.push(el);
          });
        });

        document.querySelectorAll('[id^="smile-"]').forEach(function(el) {
          if (el.id === 'smile-ui-lite-container' || el.tagName === 'IFRAME') return;
          if (window.getComputedStyle(el).position === 'fixed' && seen.indexOf(el) === -1) {
            seen.push(el);
          }
        });

        return seen;
      }

      function applySmilePosition(el) {
        var isMobile = window.innerWidth <= 768;

        el.style.setProperty('left', isMobile ? '50%' : '12px', 'important');
        el.style.setProperty('right', 'auto', 'important');
        el.style.setProperty('bottom', isMobile ? '65px' : '24px', 'important');
        el.style.setProperty('transform', isMobile ? 'translateX(-50%)' : 'none', 'important');
        el.style.removeProperty('display');
      }

      function syncSmile() {
        var elements = findSmileElements();
        if (!elements.length) return false;
        elements.forEach(applySmilePosition);
        return true;
      }

      function stopObservingSmile() {
        if (!smileObserver) return;
        smileObserver.disconnect();
        smileObserver = null;
      }

      function startSmileObserver() {
        if (syncSmile()) return;

        smileObserver = new MutationObserver(function() {
          if (syncSmile()) stopObservingSmile();
        });

        smileObserver.observe(document.body, { childList: true, subtree: true });
        window.setTimeout(stopObservingSmile, 10000);
      }

      if (window.OnelifeLazy) {
        window.OnelifeLazy.onIdle(startSmileObserver);
      } else if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', startSmileObserver, { once: true });
      } else {
        startSmileObserver();
      }

      window.addEventListener('resize', syncSmile, { passive: true });
    })();
    </script>
    <script>
    (function() {
      var warmKey = 'ol-account-domain-warmed-v1';

      function markWarmed() {
        try {
          sessionStorage.setItem(warmKey, '1');
        } catch (e) {}
      }

      function alreadyWarmed() {
        try {
          return sessionStorage.getItem(warmKey) === '1';
        } catch (e) {
          return false;
        }
      }

      function addPreconnect(href) {
        if (document.head.querySelector('link[rel="preconnect"][href="' + href + '"]')) return;
        var link = document.createElement('link');
        link.rel = 'preconnect';
        link.href = href;
        link.crossOrigin = 'anonymous';
        document.head.appendChild(link);
      }

      function warmAccountDomain() {
        if (alreadyWarmed()) return;
        markWarmed();
        addPreconnect('https://account.onelife.co.za');
      }

      function isAccountEntryLink(target) {
        if (!target.closest) return false;

        return target.closest(
          'a[href*="account.onelife.co.za"], a[href*="/customer_authentication/login"], a[href*="/account/login"]'
        );
      }

      document.addEventListener('pointerenter', function(event) {
        if (isAccountEntryLink(event.target)) {
          warmAccountDomain();
        }
      }, { capture: true, passive: true });

      document.addEventListener('touchstart', function(event) {
        if (isAccountEntryLink(event.target)) {
          warmAccountDomain();
        }
      }, { capture: true, passive: true });

    })();
    </script>
    <script>
    (function() {
      var vividPath = '/collections/vivid-health';
      var vividView = vividPath + '?view=vivid-guide';

      function normalizeVividLinks() {
        document.querySelectorAll('a[href]').forEach(function(link) {
          var href = link.getAttribute('href');
          if (href === vividPath || href === 'https://onelife.co.za' + vividPath || href === window.location.origin + vividPath) {
            link.setAttribute('href', vividView);
          }
        });
      }

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', normalizeVividLinks, { once: true });
      } else {
        normalizeVividLinks();
      }

      document.addEventListener('shopify:section:load', normalizeVividLinks);
    })();
    </script>
    <script>
    (function() {
      var guidePath = '/pages/product-tag-guide?view=product-tag-guide-v7';

      function isOldTagGuideLink(link) {
        var href = link.getAttribute('href') || '';
        if (href !== '/pages/faq' && href !== 'https://onelife.co.za/pages/faq' && href !== window.location.origin + '/pages/faq') return false;

        var text = (link.textContent || '').toLowerCase();
        if (text.indexOf('tag guide') !== -1 || text.indexOf('product tag') !== -1 || text.indexOf('shopping guide') !== -1) return true;

        return !!link.closest('.ol-tag-disclaimer, .ol-cart-tag-disclaimer, .shop-tag-note, .vb-note, .ol-home-tabs__tag-note, .ol-footer-tag-guide, footer');
      }

      function normalizeProductTagGuideLinks() {
        document.querySelectorAll('a[href]').forEach(function(link) {
          if (isOldTagGuideLink(link)) {
            link.setAttribute('href', guidePath);
          }
        });
      }

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', normalizeProductTagGuideLinks, { once: true });
      } else {
        normalizeProductTagGuideLinks();
      }

      document.addEventListener('shopify:section:load', normalizeProductTagGuideLinks);
    })();
