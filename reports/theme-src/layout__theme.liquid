        assign ol_title = 'Your Cart | One Life Health'
      elsif request.page_type == 'search'
        assign ol_title = 'Search Results | One Life Health'
      elsif request.page_type == '404'
        assign ol_title = 'Page Not Found | One Life Health'
      elsif request.page_type == 'blog' and blog
        assign ol_title = blog.title | append: ' | One Life Health'
      endif

