    <script>
      (function () {
        var noisyParams = ["_su_rec", "_su_rec_id"];

        function cleanUrl(value) {
          try {
            var url = new URL(value, window.location.origin);
            var changed = false;
            noisyParams.forEach(function (key) {
              if (url.searchParams.has(key)) {
                url.searchParams.delete(key);
                changed = true;
              }
            });
            return changed ? url : null;
          } catch (error) {
            return null;
          }
        }

        function sameStore(url) {
          return url.origin === window.location.origin && /\/cart\/?$/.test(url.pathname);
        }

        var current = cleanUrl(window.location.href);
        if (current) {
          window.history.replaceState({}, "", current.pathname + current.search + current.hash);
        }

        document.addEventListener("click", function (event) {
          var link = event.target && event.target.closest ? event.target.closest("a[href]") : null;
          if (!link) return;
          var cleaned = cleanUrl(link.href);
          if (!cleaned || !sameStore(cleaned)) return;
          event.preventDefault();
          window.location.assign(cleaned.pathname + cleaned.search + cleaned.hash);
        }, true);

        document.addEventListener("submit", function (event) {
          var form = event.target;
          if (!form || !form.action) return;
          var cleaned = cleanUrl(form.action);
          if (!cleaned || !sameStore(cleaned)) return;
          form.action = cleaned.pathname + cleaned.search + cleaned.hash;
        }, true);
      })();
    </script>
