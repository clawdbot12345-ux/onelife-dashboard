.ol-tag-hero{position:relative;min-height:430px;display:flex;align-items:center;background:linear-gradient(90deg,rgba(13,28,20,.78),rgba(13,28,20,.38) 48%,rgba(13,28,20,.06)),url({{ 'onelife-product-page-lifestyle-strip.jpg' | asset_url }}) center/cover no-repeat;color:#fff}
.ol-tag-hero__inner{width:min(1180px,100vw);margin:0 auto;padding:58px 24px}
.ol-tag-kicker{display:inline-flex;align-items:center;border:1px solid rgba(255,255,255,.36);border-radius:999px;background:rgba(255,255,255,.12);backdrop-filter:blur(8px);color:#eaf7ed;font-size:12px;font-weight:850;letter-spacing:.08em;text-transform:uppercase;padding:7px 12px;margin:0 0 18px}
.ol-tag-hero h1,.ol-tag-hero .ol-tag-hero__inner h1{max-width:min(680px,calc(100vw - 32px));font-size:clamp(36px,5vw,64px);line-height:1.02;margin:0 0 16px;color:#fff!important;-webkit-text-fill-color:#fff!important;letter-spacing:0;text-wrap:balance}
.ol-tag-hero__lead{max-width:min(650px,calc(100vw - 32px));font-size:18px;line-height:1.62;margin:0;color:rgba(255,255,255,.9);white-space:normal!important;overflow-wrap:break-word}
.ol-tag-hero__actions{display:flex;flex-wrap:wrap;gap:10px;margin-top:24px}
.ol-tag-btn{display:inline-flex;align-items:center;justify-content:center;min-height:44px;border-radius:8px;padding:0 18px;font-size:14px;font-weight:850;text-decoration:none}
.ol-tag-btn--light{background:#fff;color:#163625}
.ol-tag-btn--ghost{border:1px solid rgba(255,255,255,.42);color:#fff;background:rgba(255,255,255,.1)}
.ol-tag-shell{max-width:1180px;margin:0 auto;padding:34px 24px 58px}
.ol-tag-trust{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:12px;margin-top:-58px;position:relative;z-index:2}
.ol-tag-trust__item{background:#fff;border:1px solid #dde8dd;border-radius:8px;padding:18px;box-shadow:0 12px 34px rgba(26,39,31,.08)}
.ol-tag-trust__item strong{display:block;color:#163625;font-size:14px;margin-bottom:5px}
.ol-tag-trust__item span{display:block;color:#536157;font-size:13px;line-height:1.45}
.ol-tag-note{border:1px solid #d1dfd1;border-radius:8px;background:#fff;color:#35443b;font-size:15px;line-height:1.62;margin:28px 0 0;padding:18px 20px}
.ol-tag-note strong{color:#163625}
.ol-tag-section{margin-top:34px}
.ol-tag-section__head{display:flex;align-items:flex-end;justify-content:space-between;gap:18px;margin-bottom:16px}
.ol-tag-section__head h2{font-size:clamp(25px,3vw,34px);line-height:1.15;margin:0;color:#111b15;letter-spacing:0}
.ol-tag-section__head p{max-width:520px;margin:0;color:#5a665f;font-size:14px;line-height:1.55}
.ol-tag-grid{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:14px}
.ol-tag-card{background:#fff;border:1px solid #e0e8df;border-radius:8px;padding:18px;min-height:158px;box-shadow:0 1px 2px rgba(18,28,22,.04)}
.ol-tag-chip{display:inline-flex;align-items:center;border-radius:999px;background:#edf5ee;color:#1b4332;font-size:11px;font-weight:850;line-height:1;padding:7px 10px;margin-bottom:12px}
.ol-tag-card h3{font-size:18px;line-height:1.22;margin:0 0 8px;color:#111b15;letter-spacing:0}
.ol-tag-card p{font-size:13px;line-height:1.56;margin:0;color:#536157}
.ol-tag-checks{display:grid;grid-template-columns:minmax(0,1.05fr) minmax(280px,.95fr);gap:18px;align-items:stretch}
.ol-tag-panel{background:#fff;border:1px solid #dfe8df;border-radius:8px;padding:24px}
