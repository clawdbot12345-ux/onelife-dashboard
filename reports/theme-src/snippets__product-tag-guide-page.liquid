.ol-tag-list li{position:relative;padding-left:20px;color:#47564d;font-size:14px;line-height:1.55}
.ol-tag-list li:before{content:"";position:absolute;left:0;top:.66em;width:7px;height:7px;border-radius:999px;background:#2d6a4f}
