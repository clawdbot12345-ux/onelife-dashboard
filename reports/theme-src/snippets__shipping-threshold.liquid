{%- assign nationwide_threshold = 40000 -%}
{%- assign cart_total = cart.total_price -%}
{%- assign remaining = nationwide_threshold | minus: cart_total -%}
{%- assign progress = cart_total | times: 100 | divided_by: nationwide_threshold -%}
{%- if progress > 100 %}{% assign progress = 100 %}{% endif -%}
<style>
  .ol-shipping-threshold { display:block;width:100%;box-sizing:border-box;padding:12px 16px;margin:8px 0 12px;border:1px solid #cfe8d8;border-radius:12px;background:#f0fdf4;font-size:13px; }
  .ol-shipping-threshold__message { color:#333;margin-bottom:8px;text-align:center; }
  .ol-shipping-threshold__message strong,.ol-shipping-threshold__success { color:#1b4332;font-weight:700; }
  .ol-shipping-threshold__meter { width:100%;height:12px;margin-top:6px;overflow:hidden;border-radius:999px;background:#dce9de;box-shadow:inset 0 1px 2px rgba(27,67,50,.08); }
  .ol-shipping-threshold__fill { display:block;height:100%;width:0;min-width:{% if progress > 0 %}14px{% else %}0{% endif %};max-width:100%;border-radius:inherit;background:linear-gradient(90deg,#2d6a4f,#40916c);box-shadow:0 0 0 1px rgba(45,106,79,.08),0 4px 10px rgba(45,106,79,.18);transform-origin:left center;animation:ol-shipping-threshold-grow .7s ease-out both;transition:width .7s ease-out; }
  .ol-shipping-threshold__meta { display:flex;justify-content:space-between;gap:12px;margin-top:6px;font-size:11px;color:#2d6a4f; }
  .ol-shipping-threshold__goal { white-space:nowrap;font-weight:700; }
  .ol-shipping-threshold__note { margin-top:6px;font-size:11px;color:#49665a;text-align:center; }
  @keyframes ol-shipping-threshold-grow { from { transform:scaleX(0); } to { transform:scaleX(1); } }
</style>
<div class="ol-shipping-threshold">
  {%- if cart_total >= nationwide_threshold -%}
    <div class="ol-shipping-threshold__success ol-shipping-threshold__message">🎉 You qualify for free nationwide delivery!</div>
  {%- else -%}
    <div class="ol-shipping-threshold__message">You're <strong>{{ remaining | money }}</strong> away from nationwide free delivery.</div>
  {%- endif -%}
  <div class="ol-shipping-threshold__meter" role="progressbar" aria-valuemin="0" aria-valuemax="100" aria-valuenow="{{ progress }}">
    <span class="ol-shipping-threshold__fill" style="width: {{ progress }}%;"></span>
  </div>
  <div class="ol-shipping-threshold__meta">
    <span>{{ cart_total | money }} in cart</span>
    <span class="ol-shipping-threshold__goal">Free nationwide delivery at R400</span>
  </div>
  <div class="ol-shipping-threshold__note">Free delivery on orders over R400 nationwide. Final delivery options are confirmed at checkout.</div>
</div>
